@inject IJSRuntime JS

@if (showBanner)
{
    <div class="kf-topbar">
        <div class="kf-topbar-inner">
            <div class="kf-topbar-copy">
                <span class="kf-topbar-dot"></span>
                <span class="kf-topbar-message">@BannerText</span>
                <a href="@BannerCtaHref" class="kf-topbar-cta">@BannerCtaText</a>
            </div>
            <button class="kf-topbar-close" type="button" @onclick="CloseBanner" aria-label="Luk besked">×</button>
        </div>
    </div>
}

<nav class="kf-nav @(showBanner ? "with-topbar" : "")">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">By KrydsFelt</span></a>

        <div class="kf-nav-center">
            <div class="kf-nav-links">
                <a href="/" class="@GetLinkClass("home")">Hjem</a>
                <a href="/om-os" class="@GetLinkClass("about")">Om os</a>

                <div class="kf-nav-dropdown @(IsServicesActive ? "active" : "")">
                    <a href="/ydelser" class="kf-nav-dropdown-trigger">Ydelser</a>
                    <div class="kf-nav-dropdown-menu">
                        <a href="/ydelser#brand-strategi">Brand Strategy</a>
                        <a href="/ydelser#webudvikling">Web Development</a>
                        <a href="/ydelser#lead-generation">Lead Generation</a>
                        <a href="/ydelser#design-ux">Design & UX</a>
                    </div>
                </div>
                <a href="/booking" class="@GetLinkClass("contact")">Kontakt</a>
            </div>
        </div>

        <div class="kf-nav-utilities">
            <div class="kf-nav-dropdown kf-nav-dropdown-click kf-nav-language @(languageMenuOpen ? "open" : "")">
                <button
                    type="button"
                    class="kf-nav-dropdown-trigger kf-nav-language-trigger"
                    @onclick="ToggleLanguageMenu"
                    aria-label="@($"Vælg sprog. Aktuelt sprog er {CurrentLanguage.Label}.")"
                    aria-expanded="@languageMenuOpen"
                    aria-controls="kf-nav-language-menu">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="8.5"></circle>
                        <path d="M3.8 9.25h16.4"></path>
                        <path d="M3.8 14.75h16.4"></path>
                        <path d="M12 3.5c2.3 2.2 3.6 5.17 3.6 8.5S14.3 18.3 12 20.5c-2.3-2.2-3.6-5.17-3.6-8.5S9.7 5.7 12 3.5Z"></path>
                    </svg>
                </button>

                <div id="kf-nav-language-menu" class="kf-nav-dropdown-menu kf-nav-language-menu" role="menu">
                    @foreach (var language in LanguageOptions)
                    {
                        <button
                            type="button"
                            class="kf-nav-language-option @(selectedLanguageCode == language.Code ? "active" : "")"
                            @onclick="() => SelectLanguage(language.Code)"
                            role="menuitem">
                            <span>@language.Label</span>
                            <span class="kf-nav-language-code">@language.ShortLabel</span>
                        </button>
                    }
                </div>
            </div>

            <button class="kf-nav-hamburger @(navOpen ? "open" : "")" @onclick="ToggleMenu" aria-label="Menu" aria-expanded="@navOpen" aria-controls="kf-nav-mobile">
                <span></span><span></span><span></span>
            </button>

            <a href="@ContactHref" class="kf-nav-contact-btn @(CurrentPage == "booking" ? "active" : "")">@ContactLabel</a>
        </div>
    </div>

    <div id="kf-nav-mobile" class="kf-nav-mobile @(navOpen ? "open" : "")">
        <a href="/" @onclick="CloseMenu">Hjem</a>
        <a href="/om-os" @onclick="CloseMenu">Om os</a>
        <a href="/ydelser" @onclick="CloseMenu">Ydelser</a>
        <a href="/ydelser#brand-strategi" class="kf-nav-mobile-sub" @onclick="CloseMenu">Brand Strategy</a>
        <a href="/ydelser#webudvikling" class="kf-nav-mobile-sub" @onclick="CloseMenu">Web Development</a>
        <a href="/ydelser#lead-generation" class="kf-nav-mobile-sub" @onclick="CloseMenu">Lead Generation</a>
        <a href="/ydelser#design-ux" class="kf-nav-mobile-sub" @onclick="CloseMenu">Design & UX</a>
        <a href="@ContactHref" @onclick="CloseMenu">Kontakt</a>
    </div>
</nav>

@code {
    private const string LanguageStorageKey = "kf-language";

    private static readonly LanguageOption[] LanguageOptions =
    [
        new("da", "Dansk", "DA"),
        new("en", "English", "EN"),
        new("ar", "العربية", "AR"),
        new("vi", "Tiếng Việt", "VI")
    ];

    [Parameter] public string CurrentPage { get; set; } = "";
    [Parameter] public string ContactHref { get; set; } = "/booking";
    [Parameter] public string ContactLabel { get; set; } = "Book et møde";
    [Parameter] public string BannerText { get; set; } = "Klar til en ny hjemmeside?";
    [Parameter] public string BannerCtaText { get; set; } = "Book et møde";
    [Parameter] public string BannerCtaHref { get; set; } = "/booking";

    private bool navOpen;
    private bool showBanner = true;
    private bool languageMenuOpen;
    private string selectedLanguageCode = "da";

    private bool IsServicesActive => CurrentPage == "services";

    private LanguageOption CurrentLanguage =>
        LanguageOptions.First(option => option.Code == selectedLanguageCode);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var storedLanguage = await JS.InvokeAsync<string?>("localStorage.getItem", LanguageStorageKey);
        if (TryGetLanguage(storedLanguage, out var knownLanguage))
        {
            selectedLanguageCode = knownLanguage.Code;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetLinkClass(string key) =>
        key == "contact"
            ? (CurrentPage is "contact" or "booking" ? "kf-nav-active" : string.Empty)
            : CurrentPage == key ? "kf-nav-active" : string.Empty;

    private void ToggleMenu()
    {
        navOpen = !navOpen;
        languageMenuOpen = false;
    }

    private void ToggleLanguageMenu()
    {
        languageMenuOpen = !languageMenuOpen;
        navOpen = false;
    }

    private void CloseMenu()
    {
        navOpen = false;
        languageMenuOpen = false;
    }

    private void CloseBanner() => showBanner = false;

    private async Task SelectLanguage(string code)
    {
        if (!TryGetLanguage(code, out var language))
        {
            return;
        }

        selectedLanguageCode = language.Code;
        languageMenuOpen = false;
        navOpen = false;
        await JS.InvokeVoidAsync("localStorage.setItem", LanguageStorageKey, selectedLanguageCode);
    }

    private static bool TryGetLanguage(string? code, out LanguageOption language)
    {
        language = LanguageOptions.FirstOrDefault(option => option.Code == code) ?? LanguageOptions[0];
        return LanguageOptions.Any(option => option.Code == code);
    }

    private sealed record LanguageOption(string Code, string Label, string ShortLabel);
}
