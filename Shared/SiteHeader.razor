@inherits LocalizedComponentBase
@inject IJSRuntime JS

@if (showBanner)
{
    <div class="kf-topbar">
        <div class="kf-topbar-inner">
            <div class="kf-topbar-copy">
                <span class="kf-topbar-dot"></span>
                <span class="kf-topbar-message">@Lang.T("banner.text")</span>
                <a href="@BannerCtaHref" class="kf-topbar-cta">@Lang.T("banner.cta")</a>
            </div>
            <button class="kf-topbar-close" type="button" @onclick="CloseBanner" aria-label="@Lang.T("nav.closeMessage")">×</button>
        </div>
    </div>
}

<nav class="kf-nav @(showBanner ? "with-topbar" : "")">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">By KrydsFelt</span></a>

        <div class="kf-nav-center">
            <div class="kf-nav-links">
                <a href="/" class="@GetLinkClass("home")">@Lang.T("nav.home")</a>
                <a href="/om-os" class="@GetLinkClass("about")">@Lang.T("nav.about")</a>

                <div class="kf-nav-dropdown @(IsServicesActive ? "active" : "")">
                    <a href="/ydelser" class="kf-nav-dropdown-trigger">@Lang.T("nav.services")</a>
                    <div class="kf-nav-dropdown-menu">
                        <a href="/ydelser/webudvikling">@Lang.T("nav.services.web")</a>
                        <a href="/ydelser/meta-ads">@Lang.T("nav.services.metaads")</a>
                        <a href="/ydelser/branding-design">@Lang.T("nav.services.branding")</a>
                        <a href="/ydelser/custom-project">@Lang.T("nav.services.custom")</a>
                        <a href="/booking">@Lang.T("nav.services.integration")</a>
                    </div>
                </div>
                <a href="/booking" class="@GetLinkClass("contact")">@Lang.T("nav.contact")</a>
            </div>
        </div>

        <div class="kf-nav-utilities">
            <div class="kf-nav-dropdown kf-nav-dropdown-click kf-nav-language @(languageMenuOpen ? "open" : "")">
                <button
                    type="button"
                    class="kf-nav-dropdown-trigger kf-nav-language-trigger"
                    @onclick="ToggleLanguageMenu"
                    aria-label="@string.Format(Lang.T("nav.langSelect"), CurrentLanguage.Label)"
                    aria-expanded="@languageMenuOpen"
                    aria-controls="kf-nav-language-menu">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="8.5"></circle>
                        <path d="M3.8 9.25h16.4"></path>
                        <path d="M3.8 14.75h16.4"></path>
                        <path d="M12 3.5c2.3 2.2 3.6 5.17 3.6 8.5S14.3 18.3 12 20.5c-2.3-2.2-3.6-5.17-3.6-8.5S9.7 5.7 12 3.5Z"></path>
                    </svg>
                </button>

                <div id="kf-nav-language-menu" class="kf-nav-dropdown-menu kf-nav-language-menu" role="menu">
                    @foreach (var language in LanguageOptions)
                    {
                        <button
                            type="button"
                            class="kf-nav-language-option @(Lang.CurrentLanguage == language.Code ? "active" : "")"
                            @onclick="() => SelectLanguage(language.Code)"
                            role="menuitem">
                            <span>@language.Label</span>
                            <span class="kf-nav-language-code">@language.ShortLabel</span>
                        </button>
                    }
                </div>
            </div>

            <button class="kf-nav-hamburger @(navOpen ? "open" : "")" @onclick="ToggleMenu" aria-label="Menu" aria-expanded="@navOpen" aria-controls="kf-nav-mobile">
                <span></span><span></span><span></span>
            </button>

            <a href="@ContactHref" class="kf-nav-contact-btn @(CurrentPage == "booking" ? "active" : "")">@Lang.T("nav.bookMeeting")</a>
        </div>
    </div>

    <div id="kf-nav-mobile" class="kf-nav-mobile @(navOpen ? "open" : "")">
        <a href="/" @onclick="CloseMenu">@Lang.T("nav.home")</a>
        <a href="/om-os" @onclick="CloseMenu">@Lang.T("nav.about")</a>
        <a href="/ydelser" @onclick="CloseMenu">@Lang.T("nav.services")</a>
        <a href="/ydelser/webudvikling" class="kf-nav-mobile-sub" @onclick="CloseMenu">@Lang.T("nav.services.web")</a>
        <a href="/ydelser/meta-ads" class="kf-nav-mobile-sub" @onclick="CloseMenu">@Lang.T("nav.services.metaads")</a>
        <a href="/ydelser/branding-design" class="kf-nav-mobile-sub" @onclick="CloseMenu">@Lang.T("nav.services.branding")</a>
        <a href="/ydelser/custom-project" class="kf-nav-mobile-sub" @onclick="CloseMenu">@Lang.T("nav.services.custom")</a>
        <a href="/booking" class="kf-nav-mobile-sub" @onclick="CloseMenu">@Lang.T("nav.services.integration")</a>
        <a href="@ContactHref" @onclick="CloseMenu">@Lang.T("nav.contact")</a>
    </div>
</nav>

@code {
    private static readonly LanguageOption[] LanguageOptions =
    [
        new("da", "Dansk", "DA"),
        new("en", "English", "EN")
    ];

    [Parameter] public string CurrentPage { get; set; } = "";
    [Parameter] public string ContactHref { get; set; } = "/booking";
    [Parameter] public string BannerCtaHref { get; set; } = "/booking";

    private bool navOpen;
    private bool showBanner = true;
    private bool languageMenuOpen;

    private bool IsServicesActive => CurrentPage == "services";

    private LanguageOption CurrentLanguage =>
        LanguageOptions.First(option => option.Code == Lang.CurrentLanguage);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Lang.InitializeAsync(JS);
    }

    private string GetLinkClass(string key) =>
        key == "contact"
            ? (CurrentPage is "contact" or "booking" ? "kf-nav-active" : string.Empty)
            : CurrentPage == key ? "kf-nav-active" : string.Empty;

    private void ToggleMenu()
    {
        navOpen = !navOpen;
        languageMenuOpen = false;
    }

    private void ToggleLanguageMenu()
    {
        languageMenuOpen = !languageMenuOpen;
        navOpen = false;
    }

    private void CloseMenu()
    {
        navOpen = false;
        languageMenuOpen = false;
    }

    private void CloseBanner() => showBanner = false;

    private async Task SelectLanguage(string code)
    {
        languageMenuOpen = false;
        navOpen = false;
        await Lang.SetLanguageAsync(code, JS);
    }

    private sealed record LanguageOption(string Code, string Label, string ShortLabel);
}
