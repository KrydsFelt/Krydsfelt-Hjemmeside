@inherits LocalizedComponentBase

<footer class="kf-footer">
    <div class="kf-container">
        <div class="kf-footer-content">
            <div class="kf-footer-cta">
                <p class="kf-footer-cta-label">Brug for hjælp?</p>
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-footer-contact-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
                    krydsfelt.info@gmail.com
                </a>
                <a href="tel:+4550366131" class="kf-footer-contact-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    +45 50 36 61 31
                </a>
                <div style="height: 2px; width: 380px; background: var(--brand-heading-gradient); margin: 0.75rem 0;"></div>
                <a href="https://www.instagram.com/krydsfeltcom/?hl=da" target="_blank" rel="noopener noreferrer" style="margin-top: 0.25rem; display: inline-block;">
                    <img src="Pictures/Logo/new-instagram-logo-glyph.png" alt="Instagram" style="width: 28px; height: 28px; filter: brightness(0) invert(1) sepia(1) saturate(5) hue-rotate(160deg); opacity: 0.85; transition: opacity 0.2s ease;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.85'" />
                </a>
            </div>
            <div class="kf-footer-links">
                <div class="kf-footer-col">
                    <h5>@Lang.T("footer.explore")</h5>
                    <a href="/">@Lang.T("footer.home")</a>
                    <a href="/om-os">@Lang.T("footer.about")</a>
                    <a href="/ydelser">@Lang.T("footer.servicesLink")</a>
                    <a href="/booking">@Lang.T("footer.contact")</a>
                    <a href="/showcase">Showcase</a>
                </div>
                <div class="kf-footer-col">
                    <h5>@Lang.T("footer.services")</h5>
                    <a href="/ydelser/webudvikling">@Lang.T("nav.services.web")</a>
                    <a href="/ydelser/meta-ads">@Lang.T("nav.services.metaads")</a>
                    <a href="/ydelser/branding-design">@Lang.T("nav.services.branding")</a>
                    <a href="/ydelser/custom-project">@Lang.T("nav.services.custom")</a>
                </div>
            </div>
        </div>
        <div class="kf-footer-bottom">
            <p>@Lang.T("footer.copyright")</p>
        </div>
    </div>
</footer>
