@page "/om-os"
@inherits LocalizedComponentBase
@inject IJSRuntime JS

<PageTitle>Om Os – KrydsFelt</PageTitle>

<SiteHeader CurrentPage="about" ContactHref="/booking" />

<section class="kh-about-hero">
    <div class="kf-container kh-about-hero-grid kh-about-hero-grid-minimal">
        <div class="kh-about-hero-copy">
            <span class="oo2-section-label">@Lang.T("about.hero.label")</span>
            <h1 class="kh-about-title">@Lang.T("about.hero.title")</h1>
            <p class="kh-about-text">@Lang.T("about.hero.text")</p>
            <div class="kh-about-actions">
                <a href="/booking" class="kf-btn kf-btn-primary"><span>@Lang.T("about.hero.bookMeeting")</span></a>
                <a href="/ydelser" class="kf-btn kf-btn-secondary"><span>@Lang.T("about.hero.seeServices")</span></a>
            </div>
        </div>
    </div>
</section>

<section class="kh-about-values">
    <div class="kf-container">
        <div class="kh-home-section-head reveal">
            <span class="oo2-section-label">@Lang.T("about.values.label")</span>
            <h2>@Lang.T("about.values.heading")</h2>
            <p>@Lang.T("about.values.text")</p>
        </div>

        <div class="kh-about-values-grid kh-about-values-grid-minimal">
            <article class="kh-about-value-card reveal">
                <span>01</span>
                <h3>@Lang.T("about.value1.title")</h3>
                <p>@Lang.T("about.value1.desc")</p>
            </article>
            <article class="kh-about-value-card reveal" data-delay="100">
                <span>02</span>
                <h3>@Lang.T("about.value2.title")</h3>
                <p>@Lang.T("about.value2.desc")</p>
            </article>
        </div>
    </div>
</section>

<section class="kh-about-team">
    <div class="kf-container">
        <div class="kh-home-section-head reveal">
            <span class="oo2-section-label">@Lang.T("about.team.label")</span>
            <h2>@Lang.T("about.team.heading")</h2>
            <p>@Lang.T("about.team.text")</p>
        </div>

        <div class="kh-about-team-grid">
            <article class="kh-about-team-card reveal">
                <img src="Pictures/Tony.jpeg" alt="Tony Truong" />
                <div>
                    <h3>Tony Truong</h3>
                    <p>Founder & CTO</p>
                    <span>@Lang.T("about.tony.bio")</span>
                </div>
            </article>
            <article class="kh-about-team-card reveal" data-delay="100">
                <img src="Pictures/Gio.jpeg" alt="Giorgio Kevin Beshara" />
                <div>
                    <h3>Giorgio Kevin Beshara</h3>
                    <p>Co-Founder & Developer</p>
                    <span>@Lang.T("about.gio.bio")</span>
                </div>
            </article>
            <article class="kh-about-team-card reveal" data-delay="200">
                <img src="Pictures/Minh.jpeg" alt="Minh Quan Dinh" />
                <div>
                    <h3>Minh Quan Dinh</h3>
                    <p>Co-Founder & Developer</p>
                    <span>@Lang.T("about.minh.bio")</span>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="kh-about-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">@Lang.T("about.cta.label")</span>
        <h2>@Lang.T("about.cta.heading")</h2>
        <p>@Lang.T("about.cta.text")</p>
        <a href="/booking" class="oo2-cta-link">@Lang.T("about.cta.link")</a>
    </div>
</section>

<SiteFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
