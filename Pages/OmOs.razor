@page "/om-os"
@inject IJSRuntime JS

<PageTitle>Om Os – KrydsFelt</PageTitle>

<!-- NAV -->
<nav class="kf-nav">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
        <div class="kf-nav-links">
            <a href="/ydelser">Ydelser</a>
            <a href="/om-os" class="kf-nav-active">Om os</a>
        </div>
        <button class="kf-nav-hamburger @(navOpen ? "open" : "")" @onclick="() => navOpen = !navOpen" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <a href="/#contact" class="kf-nav-contact-btn">Kontakt</a>
    </div>
    <div class="kf-nav-mobile @(navOpen ? "open" : "")">
        <a href="/ydelser" @onclick="() => navOpen = false">Ydelser</a>
        <a href="/om-os" @onclick="() => navOpen = false">Om os</a>
        <a href="/#contact" @onclick="() => navOpen = false">Kontakt</a>
    </div>
</nav>

<!-- HERO - ABOUT US INTRO -->
<section class="oo-hero-v2">
    <div class="kf-container">
        <div class="oo-hero-content">
            <span class="oo-hero-label">OM OS</span>
            <h1>Systemet bag digital vækst</h1>
            <p class="oo-hero-subtitle">At KrydsFelt, strategi, udførelse og performance hænger tæt sammen. Vi bygger digitale infrastrukturer, hvor systemer arbejder sammen for at støtte virksomheder i deres næste vækstfase.</p>
        </div>
    </div>
</section>

<!-- PRINCIPLES SECTION - FULL BLUE BACKGROUND -->
<section class="oo-principles">
    <div class="oo-principles-content">
        <h2 class="oo-principles-title">Hvor alt forbindes</h2>
        <p class="oo-principles-text">Vi bygger hvad der virker</p>
    </div>
</section>

<!-- FOUNDER'S VISION SECTION -->
<section class="oo-founder">
    <div class="kf-container">
        <div class="oo-founder-layout">
            <div class="oo-founder-left reveal">
                <span class="oo-founder-label">FOUNDERS VISION</span>
                <p class="oo-founder-text">
                    Den digitale verden har ændret sig fundamentalt. Beslutninger går hurtigere, teknologi udvikler sig konstant, og performance måles i realtid. I dette miljø er isoleret udførelse ikke længere nok. KrydsFelt blev grundlagt på troen om, at digital vækst bliver skalerbar kun, når strategi, udførelse og optimering fungerer som ét system. Det kræver fokus, struktur og ansvar på strategisk niveau.
                </p>
            </div>
            <div class="oo-founder-right">
                <div class="oo-founder-image">
                    <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
                </div>
                <h3>Tony Xtruong</h3>
                <p>Founder & CTO, KrydsFelt</p>
            </div>
        </div>
    </div>
</section>

<!-- MEET THE TEAM SECTION -->
<section class="oo-team">
    <div class="kf-container">
        <div class="oo-team-header reveal">
            <h2>Mød Teamet</h2>
            <p>Tre passionerede udvikler fra Aarhus med fælles vision</p>
        </div>

        <div class="oo-team-grid">
            <div class="oo-team-card reveal">
                <div class="oo-team-card-image">
                    <img src="Pictures/Tony.jpeg" alt="Tony" />
                </div>
                <h3>Tony Xtruong</h3>
                <p>Founder & CTO</p>
                <span class="oo-team-desc">Backend-ekspertise og teknisk arkitektur</span>
            </div>

            <div class="oo-team-card reveal" data-delay="100">
                <div class="oo-team-card-image">
                    <img src="Pictures/Gio.jpeg" alt="Gio" />
                </div>
                <h3>Gio</h3>
                <p>Co-Founder & Developer</p>
                <span class="oo-team-desc">Frontend udvikling og design</span>
            </div>

            <div class="oo-team-card reveal" data-delay="200">
                <div class="oo-team-card-image">
                    <img src="Pictures/Minh.jpeg" alt="Minh" />
                </div>
                <h3>Minh</h3>
                <p>Co-Founder & Developer</p>
                <span class="oo-team-desc">Full-stack udvikling og systemer</span>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="oo-cta">
    <div class="kf-container oo-cta-inner">
        <h2>Klar til at diskutere din digitale vækst?</h2>
        <p>Lad os tale om dit projekt og se, hvad vi kan bygge sammen.</p>
        <a href="/#contact" class="oo-cta-btn">BOOK ET MØDE →</a>
    </div>
</section>

<!-- FOOTER -->
<footer class="kf-footer">
    <div class="kf-container">
        <div class="kf-footer-content">
            <div class="kf-footer-cta">
                <p class="kf-footer-cta-label">Klar til at blive noget stort?</p>
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-footer-email">krydsfelt.info@gmail.com</a>
                <p style="font-size: 0.85rem; color: #999; margin-top: 0.75rem; font-weight: 500;">Tony Xtruong, Founder & CTO</p>
            </div>
            <div class="kf-footer-links">
                <div class="kf-footer-col">
                    <h5>Udforsk</h5>
                    <a href="/">Hjem</a>
                    <a href="/ydelser">Ydelser</a>
                    <a href="/om-os">Om os</a>
                    <a href="/#contact">Kontakt</a>
                </div>
                <div class="kf-footer-col">
                    <h5>Sociale</h5>
                    <a href="#" target="_blank">LinkedIn</a>
                    <a href="#" target="_blank">Instagram</a>
                    <a href="#" target="_blank">GitHub</a>
                </div>
            </div>
        </div>
        <div class="kf-footer-bottom">
            <p>&copy; 2026 KrydsFelt. Alle rettigheder forbeholdes.</p>
        </div>
    </div>
</footer>

@code {
    bool navOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
