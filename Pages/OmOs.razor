@page "/om-os"
@inject IJSRuntime JS

<PageTitle>Om Os – KrydsFelt</PageTitle>

<SiteHeader CurrentPage="about" ContactHref="/booking" />

<section class="kh-about-hero">
    <div class="kf-container kh-about-hero-grid kh-about-hero-grid-minimal">
        <div class="kh-about-hero-copy">
            <span class="oo2-section-label">About</span>
            <h1 class="kh-about-title">Et mindre digitalt team med fokus på websites, struktur og mere præcis execution.</h1>
            <p class="kh-about-text">
                KrydsFelt består af designere og udviklere, der arbejder tæt sammen om at bygge løsninger, som både føles stærkere visuelt og fungerer bedre i praksis.
                Vi holder det bevidst enkelt, fordi det giver bedre beslutninger og mindre friktion.
            </p>
            <div class="kh-about-actions">
                <a href="/booking" class="kf-btn kf-btn-primary"><span>Book et møde</span></a>
                <a href="/ydelser" class="kf-btn kf-btn-secondary"><span>Se services</span></a>
            </div>
        </div>
    </div>
</section>

<section class="kh-about-values">
    <div class="kf-container">
        <div class="kh-home-section-head reveal">
            <span class="oo2-section-label">Hvordan vi arbejder</span>
            <h2>Vi prøver ikke at fylde mere. Vi prøver at gøre det vigtigste bedre.</h2>
            <p>Det betyder færre lag, mere ejerskab og et setup hvor kvaliteten sidder i detaljerne.</p>
        </div>

        <div class="kh-about-values-grid kh-about-values-grid-minimal">
            <article class="kh-about-value-card reveal">
                <span>01</span>
                <h3>Klar retning</h3>
                <p>Vi starter med at forstå hvad siden eller systemet faktisk skal gøre for virksomheden.</p>
            </article>
            <article class="kh-about-value-card reveal" data-delay="100">
                <span>02</span>
                <h3>Tæt samarbejde</h3>
                <p>Du arbejder tættere på dem der designer og bygger, i stedet for gennem flere led.</p>
            </article>
        </div>
    </div>
</section>

<section class="kh-about-team">
    <div class="kf-container">
        <div class="kh-home-section-head reveal">
            <span class="oo2-section-label">Team</span>
            <h2>Tre profiler. Ét samlet leveranceteam.</h2>
            <p>Vi holder holdet lille med vilje, så der er kort vej fra idé til implementering.</p>
        </div>

        <div class="kh-about-team-grid">
            <article class="kh-about-team-card reveal">
                <img src="Pictures/Tony.jpeg" alt="Tony Truong" />
                <div>
                    <h3>Tony Truong</h3>
                    <p>Founder & CTO</p>
                    <span>Megamind bag backend, arkitektur og den tekniske retning. Den slags profil der får tunge tekniske ting til at opføre sig langt pænere, end de egentlig har lyst til.</span>
                </div>
            </article>
            <article class="kh-about-team-card reveal" data-delay="100">
                <img src="Pictures/Gio.jpeg" alt="Giorgio Kevin Beshara" />
                <div>
                    <h3>Giorgio Kevin Beshara</h3>
                    <p>Co-Founder & Developer</p>
                    <span>Kan, hvis nødvendigt, starte i Windows Paint og stadig lande i noget der ligner niveau. Ellers hedder det Figma, Framer og Adobe, når frontend og det visuelle skal sidde skarpt.</span>
                </div>
            </article>
            <article class="kh-about-team-card reveal" data-delay="200">
                <img src="Pictures/Minh.jpeg" alt="Minh Quan Dinh" />
                <div>
                    <h3>Minh Quan Dinh</h3>
                    <p>Co-Founder & Developer</p>
                    <span>Kendt internt som blæksprutten. Lidt over det hele på den gode måde, og det allround krydderi der får full-stack, integrationer og teknisk struktur til at hænge urimeligt godt sammen.</span>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="kh-about-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">Kontakt</span>
        <h2>Hvis I mangler et mindre team med mere fokus og bedre digital execution, så lad os tage første møde.</h2>
        <p>Vi tager helst projekter ind, hvor der er ambition om at bygge noget skarpere end standard.</p>
        <a href="/booking" class="oo2-cta-link">BOOK ET MØDE</a>
    </div>
</section>

<SiteFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
