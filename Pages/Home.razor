@page "/"
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<!-- NAV -->
<nav class="kf-nav">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
        <div class="kf-nav-links">
            <a href="/ydelser">Ydelser</a>
            <a href="/om-os">Om os</a>
        </div>
    </div>
    <a href="#contact" class="kf-nav-contact-btn">Kontakt</a>
</nav>

<!-- HERO -->
<section class="kf-hero">
    <div class="kf-hero-blob kf-hero-blob-1"></div>
    <div class="kf-hero-blob kf-hero-blob-2"></div>
    <div class="kf-container kf-hero-inner">
        <div class="kf-hero-left">
            <h1>Vi Bygger Digitale<br /><span class="kf-orange">Magtsystemer</span></h1>
            <p>Skræddersyede webløsninger og systemer, der gør din virksomhed stand out.<br />Vi handler hurtigt, leverer kvalitet, og får resultat.</p>
            <div class="kf-hero-actions">
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-btn">Kom i gang →</a>
            </div>
        </div>
        <div class="kf-hero-right"></div>
    </div>
</section>

<!-- SERVICES -->
<section class="kf-services" id="services">
    <div class="kf-parallax-text" aria-hidden="true">KrydsFelt</div>
    <div class="kf-container kf-services-content">
        <h2 class="reveal">Det Vi Gør</h2>
        <p class="kf-section-sub reveal" data-delay="100">Vi leverer løsninger, der transformerer virksomheder og driver resultater</p>
        <div class="kf-cards">
            <div class="kf-card reveal" data-delay="0">
                <div class="kf-icon-box">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                </div>
                <h3>Webudvikling</h3>
                <p>Moderne, lynhurtige hjemmesider og webapps, der konverterer besøgende til kunder.</p>
                <a href="/ydelser#webudvikling" class="kf-card-link">Læs mere <span class="kf-card-arrow">→</span></a>
                <span class="kf-card-num">01</span>
            </div>
            <div class="kf-card reveal" data-delay="120">
                <div class="kf-icon-box">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                    </svg>
                </div>
                <h3>Skræddersyede Systemer</h3>
                <p>Softwareløsninger bygget præcis til dine behov – ingen kompromiser, ren effektivitet.</p>
                <a href="/ydelser#systemer" class="kf-card-link">Læs mere <span class="kf-card-arrow">→</span></a>
                <span class="kf-card-num">02</span>
            </div>
            <div class="kf-card reveal" data-delay="240">
                <div class="kf-icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                    </svg>
                </div>
                <h3>Backend-løsninger</h3>
                <p>Kraftfulde systemer på stedet – skalering, sikkerhed og performance, som standard.</p>
                <a href="/ydelser#backend" class="kf-card-link">Læs mere <span class="kf-card-arrow">→</span></a>
                <span class="kf-card-num">03</span>
            </div>
            <div class="kf-card reveal" data-delay="360">
                <div class="kf-icon-box">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>
                    </svg>
                </div>
                <h3>Responsivt Design</h3>
                <p>Punch-løsninger, der ser fabelagtig ud på hver enhed – fra mobil til desktop.</p>
                <a href="/ydelser#design" class="kf-card-link">Læs mere <span class="kf-card-arrow">→</span></a>
                <span class="kf-card-num">04</span>
            </div>
        </div>
    </div>
</section>

<!-- WHY CHOOSE -->
<section class="kf-why-choose">
    <div class="kf-container kf-why-choose-inner">
        <div class="kf-why-choose-left">
            <h2>Hvorfor vælge KrydsFelt?</h2>
            <p>Vi leverer løsninger, der virker. Med erfaring på tværs af industrier, dedikerede team members, og en track record af succes – vi er dine partners for growth.</p>
            <a href="mailto:krydsfelt.info@gmail.com" class="kf-why-choose-btn">Start dit projekt</a>
        </div>
        <div class="kf-why-choose-stats">
            <div class="kf-stat-card">
                <div class="kf-stat-number">50+</div>
                <p class="kf-stat-label">Erfarne udvikler & designere</p>
                <p class="kf-stat-desc">Dedikeret team, der leverer exceptional resultat.</p>
            </div>
            <div class="kf-stat-card">
                <div class="kf-stat-number">100+</div>
                <p class="kf-stat-label">Succesfulde projekter</p>
                <p class="kf-stat-desc">Gennemført på tværs af diverse brancher.</p>
            </div>
            <div class="kf-stat-card">
                <div class="kf-stat-number">5+</div>
                <p class="kf-stat-label">År erfaring</p>
                <p class="kf-stat-desc">Bevist ekspertise, innovation og kvalitet.</p>
            </div>
            <div class="kf-stat-card">
                <div class="kf-stat-number">30+</div>
                <p class="kf-stat-label">Tilfredsne kunder</p>
                <p class="kf-stat-desc">Virksomheder, der har partneret med os til succes.</p>
            </div>
        </div>
    </div>
</section>

