@page "/"
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<SiteHeader CurrentPage="home" ContactHref="/booking" />

<section class="kh-home-hero">
    <div class="kf-container">
        <div class="kh-home-hero-grid kh-home-hero-grid-minimal">
            <div class="kh-home-hero-copy">
                <span class="kh-home-pill">Aarhus, Danmark</span>
                <h1 class="kh-home-title" data-animate="words">Vi bygger hjemmesider og digitale løsninger med mere ro, mere retning og bedre execution.</h1>
                <p class="kh-home-text reveal">
                    KrydsFelt hjælper mindre virksomheder og brands, der er vokset fra standardløsninger, men som stadig vil have et lille team tæt på processen.
                    Vi samler strategi, design og udvikling, så det færdige resultat føles mere gennemført og er lettere at bygge videre på.
                </p>
                <div class="kh-home-actions">
                    <a href="/booking" class="kf-btn kf-btn-primary"><span>Book et møde</span></a>
                    <a href="/ydelser" class="kf-btn kf-btn-secondary"><span>Se services</span></a>
                </div>
            </div>

            <div class="kh-home-hero-side reveal" data-delay="120"></div>
        </div>
    </div>
</section>

<section class="kh-home-profile">
    <div class="kf-container kh-home-profile-grid">
        <div class="kh-home-profile-copy reveal">
            <span class="oo2-section-label">Hvem er vi?</span>
            <h2>Et mindre team med fokus på at gøre digitale løsninger mere klare, mere præcise og mere brugbare.</h2>
            <p>
                Vi arbejder tæt med virksomheder, der ikke har brug for et stort bureauapparat, men stadig vil have høj kvalitet i både design og udvikling.
                Det giver kortere vej fra idé til launch og et mere sammenhængende resultat.
            </p>
            <p>
                Vores styrke er ikke volumen. Det er smag, fokus og evnen til at bygge noget der både ser bedre ud nu og holder bedre bagefter.
            </p>
            <p>
                KrydsFelt er bygget omkring et lille hold, hvor strategi, design og udvikling spiller tæt sammen. Det gør processen hurtigere, mere direkte og mindre tung.
                Når et brand eller en virksomhed har brug for et tydeligere digitalt niveau, men stadig vil arbejde tæt med dem der udfører arbejdet, er det typisk dér vi passer bedst ind.
            </p>
            <a href="/om-os" class="kh-home-inline-link">Læs mere om os</a>

            <div class="kh-home-socials">
                <a href="#" aria-label="Instagram" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.5" cy="6.5" r="1"></circle>
                    </svg>
                </a>
                <a href="#" aria-label="LinkedIn" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M6.94 8.5H3.56V20h3.38V8.5Zm-1.69-1.56c1.08 0 1.94-.74 1.94-1.72-.02-1-.86-1.72-1.92-1.72-1.06 0-1.94.72-1.94 1.72 0 .98.84 1.72 1.9 1.72h.02ZM20 13.05c0-3.47-1.85-5.08-4.32-5.08-1.99 0-2.88 1.1-3.37 1.87V8.5H8.94c.05.89 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.38 1.91-1.38 1.35 0 1.89 1.04 1.89 2.56V20H20v-6.95Z"></path>
                    </svg>
                </a>
                <a href="mailto:krydsfelt.info@gmail.com" aria-label="Email" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 7l9 6 9-6"></path>
                    </svg>
                </a>
            </div>
        </div>

        <div class="kh-home-profile-media reveal" data-delay="140">
            <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
            <div class="kh-home-profile-stats">
                <div>
                    <strong>4+</strong>
                    <span>Års erfaring</span>
                </div>
                <div>
                    <strong>43</strong>
                    <span>Partners</span>
                </div>
                <div>
                    <strong>100%</strong>
                    <span>Tilfredshed</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="kh-home-services">
    <div class="kf-container">
        <div class="kh-home-section-head reveal">
            <span class="oo2-section-label">Services</span>
            <h2>Det vi typisk hjælper med, når et website eller digitalt setup skal løftes.</h2>
            <p>Vi holder det enkelt og fokuserer på det, der gør størst forskel for næste version af virksomheden.</p>
        </div>

        <div class="kh-home-service-grid kh-home-service-grid-minimal">
            <article class="kh-home-service-card reveal">
                <span>01</span>
                <h3>Website Design & Build</h3>
                <p>Hjemmesider med bedre struktur, stærkere branding og et mere roligt, gennemført udtryk.</p>
            </article>
            <article class="kh-home-service-card reveal" data-delay="100">
                <span>02</span>
                <h3>Frontend & UX</h3>
                <p>Interfaces og brugerflows der både ser skarpere ud og fungerer bedre i praksis.</p>
            </article>
            <article class="kh-home-service-card reveal" data-delay="200">
                <span>03</span>
                <h3>Custom Development</h3>
                <p>Skræddersyede løsninger når standardværktøjer ikke længere passer til behovet.</p>
            </article>
        </div>
    </div>
</section>

<section class="kh-home-process">
    <div class="kf-container kh-home-process-grid">
        <div class="kh-home-process-copy reveal">
            <span class="oo2-section-label">Proces</span>
            <h2>En enkel proces med højere kvalitet og mindre støj.</h2>
            <p>Vi holder projektet tæt, så retningen er klar og execution bliver bedre hele vejen gennem.</p>
            <a href="/booking" class="kh-home-inline-link">Start en samtale</a>
        </div>

        <div class="kh-home-process-list">
            <article class="kh-home-process-item reveal">
                <strong>01</strong>
                <div>
                    <h3>Afklaring</h3>
                    <p>Vi starter med mål, scope og hvor løsningen skal skabe reel værdi.</p>
                </div>
            </article>
            <article class="kh-home-process-item reveal" data-delay="100">
                <strong>02</strong>
                <div>
                    <h3>Design & struktur</h3>
                    <p>Indhold, retning og visuel form sættes før vi bygger det færdige produkt.</p>
                </div>
            </article>
            <article class="kh-home-process-item reveal" data-delay="200">
                <strong>03</strong>
                <div>
                    <h3>Build & launch</h3>
                    <p>Vi designer, udvikler og afleverer noget der både kan gå live nu og fungere bagefter.</p>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="kh-home-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">Kontakt</span>
        <h2>Hvis jeres website eller digitale udtryk skal være skarpere, tager vi gerne den første samtale.</h2>
        <p>Vi passer bedst til virksomheder, der vil løfte niveauet med et lille team og en mere gennemført proces.</p>
        <a href="/booking" class="oo2-cta-link">BOOK ET MØDE</a>
    </div>
</section>

<SiteFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
