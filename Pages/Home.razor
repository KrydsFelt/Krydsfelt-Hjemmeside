@page "/"
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<!-- NAV -->
<nav class="kf-nav">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
        <div class="kf-nav-links">
            <a href="/ydelser">Ydelser</a>
            <a href="/om-os">Om os</a>
        </div>
        <button class="kf-nav-hamburger @(navOpen ? "open" : "")" @onclick="() => navOpen = !navOpen" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <a href="#contact" class="kf-nav-contact-btn">Kontakt</a>
    </div>
    <div class="kf-nav-mobile @(navOpen ? "open" : "")">
        <a href="/ydelser" @onclick="() => navOpen = false">Ydelser</a>
        <a href="/om-os" @onclick="() => navOpen = false">Om os</a>
        <a href="mailto:krydsfelt.info@gmail.com" @onclick="() => navOpen = false">Kontakt</a>
    </div>
</nav>

<!-- HERO -->
<section class="kf-hero">
    <div class="kf-container">
        <div class="kf-hero-content">
            <div class="kf-hero-status">
                <span class="kf-status-text">Europa, Danmark</span>
            </div>

            <h1 class="kf-hero-title" data-animate="words">
                Vi Bygger Digitale Magtsystemer for Vækst
            </h1>

            <p class="kf-hero-description reveal">
                Et dedikeret team af udviklere og designere baseret i Aarhus. Vi skaber skræddersyede webløsninger og systemer, der transformerer virksomheder. Hurtig levering, høj kvalitet, målbare resultater.
            </p>

            <div class="kf-hero-ctas">
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-btn kf-btn-primary">
                    <span>↳ Kom i gang</span>
                </a>
                <a href="/ydelser" class="kf-btn kf-btn-secondary">
                    <span>↳ Se vores arbejde</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- APPROACH PROCESS -->
<section class="kf-approach-process">
    <div class="kf-container">
        <div class="kf-process-intro">
            <p class="kf-process-intro-text">
                Vi bygger digitale løsninger for etablerede virksomheder, startups og alt derimelllem. Fokus er det samme: <span class="kf-process-highlight">systemer der skalerer</span>, løser de kommunikations-problemer der betyder noget, og holder <span class="kf-process-highlight">mennesker først</span> hele vejen igennem.
            </p>
        </div>

        <div class="kf-process-content">
            <div class="kf-process-left">
                <h2 data-animate="words">Vores tilgang til digital design</h2>
                <p class="reveal">
                    Vi designer digitale oplevelser der virker for de mennesker der bruger dem og de teams der vedligeholder dem. Vi starter med hvad brugerne rent faktisk skal bruge, mapper flows, tester tidligt, og bygger interfaces der ikke skal have manualer.
                </p>
                <p class="reveal" style="margin-top: 1.5rem;">
                    Arbejdet dækker UX, interaction design, information architecture og brand evolution. Design for virkelighed. Rodet sker. Hvis brugere bliver lost eller klienten ikke kan update indhold uden at bryde noget – det er et problem. God design holder stand når det bliver kompliceret.
                </p>
                <a href="/ydelser" class="kf-process-cta">↳ Se vores arbejde</a>
            </div>

            <div class="kf-process-right">
                <div class="kf-process-accordion">
                    <div class="kf-process-accordion-item">
                        <button class="kf-process-accordion-trigger">
                            <span>Strategi</span>
                            <span class="kf-process-accordion-icon">+</span>
                        </button>
                        <div class="kf-process-accordion-content">
                            <p>Vi starter med en grundig forståelse af dit marked, din målgruppe og position. Ud fra det definerer vi strukturen, strategien og retningen for din digitale platform.</p>
                        </div>
                    </div>

                    <div class="kf-process-accordion-item">
                        <button class="kf-process-accordion-trigger">
                            <span>User Experience</span>
                            <span class="kf-process-accordion-icon">+</span>
                        </button>
                        <div class="kf-process-accordion-content">
                            <p>Vi designer oplevelser omkring brugerens behov. Hver interaktion, hvert flow, hver skærm er designet for at løse problemer og skabe værdi for brugere.</p>
                        </div>
                    </div>

                    <div class="kf-process-accordion-item">
                        <button class="kf-process-accordion-trigger">
                            <span>Design</span>
                            <span class="kf-process-accordion-icon">+</span>
                        </button>
                        <div class="kf-process-accordion-content">
                            <p>Fra wireframes til pixel-perfekt design. Vi skaber visuelt sammenhængende systemer der fungerer på alle enheder og bakker virksomhedens mærke op.</p>
                        </div>
                    </div>

                    <div class="kf-process-accordion-item">
                        <button class="kf-process-accordion-trigger">
                            <span>Udvikling</span>
                            <span class="kf-process-accordion-icon">+</span>
                        </button>
                        <div class="kf-process-accordion-content">
                            <p>Vi udvikler robust, skalerbar kode der måler sig selv. Performance, sikkerhed og vedligeholdelse bygges ind fra start.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

