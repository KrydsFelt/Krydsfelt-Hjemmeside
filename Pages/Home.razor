<section class="kh-home-process">
    <div class="kf-container">
        <div class="kh-home-process-copy reveal">
            <span class="oo2-section-label">@Lang.T("home.process.label")</span>
            <h2>@Lang.T("home.process.heading")</h2>
            <p class="kh-home-process-intro-text">@Lang.T("home.process.intro")</p>
        </div>

        <article class="kh-home-process-stage reveal" data-delay="100">
            <div class="kh-home-process-stage-controls">
                <button type="button" class="kh-home-process-arrow" @onclick="PreviousProcessStep" aria-label="@Lang.T("nav.prevStep")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <button type="button" class="kh-home-process-arrow" @onclick="NextProcessStep" aria-label="@Lang.T("nav.nextStep")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                    </svg>
                </button>
            </div>

            <div class="kh-home-process-stage-grid">
                <div class="kh-home-process-stage-copy">
                    <div class="kh-home-process-stage-number">@ActiveProcessStep.Number</div>
                    <h3>@ActiveProcessStep.Title</h3>
                    <p class="kh-home-process-stage-description">@ActiveProcessStep.Description</p>

                    <div class="kh-home-process-stage-includes">
                        <ul>
                            @foreach (var item in ActiveProcessStep.Includes)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="kh-home-process-stage-media">
                    <img src="@ActiveProcessStep.ImageUrl" alt="@ActiveProcessStep.ImageAlt" loading="lazy" />
                </div>
            </div>
        </article>
    </div>
</section>

<section class="kh-home-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">@Lang.T("home.cta.label")</span>
        <h2>@Lang.T("home.cta.heading")</h2>
        <p>@Lang.T("home.cta.text")</p>
        <a href="/booking" class="oo2-cta-link">@Lang.T("home.cta.link")</a>
    </div>
</section>

<SiteFooter />

@code {
    private int activeProcessStepIndex;
    private bool _reanimationNeeded;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Lang.OnLanguageChanged += OnLangChanged;
    }

    private void OnLangChanged() => _reanimationNeeded = true;

    private ProcessStep ActiveProcessStep => GetProcessSteps()[activeProcessStepIndex];

    private ProcessStep[] GetProcessSteps() =>
    [
        new(
            "01",
            Lang.T("home.step1.title"),
            Lang.T("home.step1.desc"),
            [
                Lang.T("home.step1.i1"),
                Lang.T("home.step1.i2"),
                Lang.T("home.step1.i3"),
                Lang.T("home.step1.i4")
            ],
            "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step1.alt")
        ),
        new(
            "02",
            Lang.T("home.step2.title"),
            Lang.T("home.step2.desc"),
            [
                Lang.T("home.step2.i1"),
                Lang.T("home.step2.i2"),
                Lang.T("home.step2.i3"),
                Lang.T("home.step2.i4")
            ],
            "https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step2.alt")
        ),
        new(
            "03",
            Lang.T("home.step3.title"),
            Lang.T("home.step3.desc"),
            [
                Lang.T("home.step3.i1"),
                Lang.T("home.step3.i2"),
                Lang.T("home.step3.i3"),
                Lang.T("home.step3.i4")
            ],
            "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step3.alt")
        )
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _reanimationNeeded)
        {
            _reanimationNeeded = false;
            await JS.InvokeVoidAsync("initAnimations");
        }
    }

    public new void Dispose()
    {
        Lang.OnLanguageChanged -= OnLangChanged;
        base.Dispose();
    }

    private void PreviousProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex - 1 + 3) % 3;
    }

    private void NextProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex + 1) % 3;
    }

    private sealed record ProcessStep(
        string Number,
        string Title,
        string Description,
        string[] Includes,
        string ImageUrl,
        string ImageAlt);
}
