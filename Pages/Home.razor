@page "/"
@inherits LocalizedComponentBase
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<SiteHeader CurrentPage="home" ContactHref="/booking" />

<section class="kh-home-hero">
    <div class="kf-container">
        <div class="kh-home-hero-grid kh-home-hero-grid-minimal">
            <div class="kh-home-hero-copy">
                <div class="kh-hero-spots-badge">
                    <span class="kh-hero-spots-dot"></span>
                    @Lang.T("home.hero.spotsLabel")
                </div>
                <h1 class="kh-home-title" data-animate="words" @key="Lang.CurrentLanguage">@Lang.T("home.hero.title")</h1>
                <p class="kh-home-text reveal">@Lang.T("home.hero.text")</p>
                <div class="kh-home-actions">
                    <a href="/booking" class="kf-btn kf-btn-primary"><span>@Lang.T("home.hero.bookMeeting")</span></a>
                </div>
            </div>
        </div>
    </div>
    <div class="kh-trust-banner">
        <div class="kf-container">
            <div class="kh-trust-track-wrapper">
