@page "/"
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<SiteHeader CurrentPage="home" ContactHref="/booking" />

<section class="kh-home-hero">
    <div class="kf-container">
        <div class="kh-home-hero-grid kh-home-hero-grid-minimal">
            <div class="kh-home-hero-copy">
                <h1 class="kh-home-title" data-animate="words">Vi bygger hjemmesider og digitale løsninger med mere ro, mere retning og bedre execution.</h1>
                <p class="kh-home-text reveal">
                    KrydsFelt hjælper mindre virksomheder og brands, der er vokset fra standardløsninger, men som stadig vil have et lille team tæt på processen.
                    Vi samler strategi, design og udvikling, så det færdige resultat føles mere gennemført og er lettere at bygge videre på.
                </p>
                <div class="kh-home-actions">
                    <a href="/booking" class="kf-btn kf-btn-primary"><span>Book et møde</span></a>
                    <a href="/ydelser" class="kf-btn kf-btn-secondary"><span>Se services</span></a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="kh-home-profile">
    <div class="kf-container kh-home-profile-grid">
        <div class="kh-home-profile-copy reveal">
            <span class="oo2-section-label">Hvem er vi?</span>
            <h2>Et mindre team med fokus på at gøre digitale løsninger mere klare, mere præcise og mere brugbare.</h2>

            <div class="kh-home-profile-media kh-home-profile-media-mobile reveal">
                <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
                <div class="kh-home-profile-stats">
                    <div><strong>4+</strong><span>Års erfaring</span></div>
                    <div><strong>43</strong><span>Partners</span></div>
                    <div><strong>100%</strong><span>Tilfredshed</span></div>
                </div>
            </div>

            <p>
                Vi arbejder tæt med virksomheder, der ikke har brug for et stort bureauapparat, men stadig vil have høj kvalitet i både design og udvikling.
                Det giver kortere vej fra idé til launch og et mere sammenhængende resultat.
            </p>
            <p>
                Vores styrke er ikke volumen. Det er smag, fokus og evnen til at bygge noget der både ser bedre ud nu og holder bedre bagefter.
            </p>
            <p>
                KrydsFelt er bygget omkring et lille hold, hvor strategi, design og udvikling spiller tæt sammen. Det gør processen hurtigere, mere direkte og mindre tung.
                Når et brand eller en virksomhed har brug for et tydeligere digitalt niveau, men stadig vil arbejde tæt med dem der udfører arbejdet, er det typisk dér vi passer bedst ind.
            </p>
            <a href="/om-os" class="kh-home-inline-link">Læs mere om os</a>

            <div class="kh-home-socials">
                <a href="#" aria-label="Instagram" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.5" cy="6.5" r="1"></circle>
                    </svg>
                </a>
                <a href="#" aria-label="LinkedIn" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M6.94 8.5H3.56V20h3.38V8.5Zm-1.69-1.56c1.08 0 1.94-.74 1.94-1.72-.02-1-.86-1.72-1.92-1.72-1.06 0-1.94.72-1.94 1.72 0 .98.84 1.72 1.9 1.72h.02ZM20 13.05c0-3.47-1.85-5.08-4.32-5.08-1.99 0-2.88 1.1-3.37 1.87V8.5H8.94c.05.89 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.38 1.91-1.38 1.35 0 1.89 1.04 1.89 2.56V20H20v-6.95Z"></path>
                    </svg>
                </a>
                <a href="mailto:krydsfelt.info@gmail.com" aria-label="Email" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 7l9 6 9-6"></path>
                    </svg>
                </a>
            </div>
        </div>

        <div class="kh-home-profile-media reveal" data-delay="140">
            <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
            <div class="kh-home-profile-stats">
                <div>
                    <strong>4+</strong>
                    <span>Års erfaring</span>
                </div>
                <div>
                    <strong>43</strong>
                    <span>Samarbejder</span>
                </div>
                <div>
                    <strong>100%</strong>
                    <span>Tilfredshed</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="kh-home-services">
    <div class="kf-container">
        <div class="kh-home-services-top reveal">
            <div class="kh-home-section-head">
                <span class="oo2-section-label">Services</span>
                <h2>Det vi typisk hjælper med, når et website eller digitalt setup skal løftes.</h2>
                <p>Vi holder det enkelt og fokuserer på det, der gør størst forskel for næste version af virksomheden.</p>
            </div>

            <a href="/ydelser" class="kh-home-services-link">Se alle ydelser</a>
        </div>

        <div class="kh-home-service-grid kh-home-service-grid-featured">
            <article class="kh-home-service-card kh-home-service-card-featured reveal">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 18h16"></path>
                        <path d="M7 18V9"></path>
                        <path d="M12 18V6"></path>
                        <path d="M17 18v-4"></path>
                        <path d="M5 9.5 9 6l3 2.5 6-4"></path>
                    </svg>
                </div>
                <h3>Webdesign & udvikling</h3>
                <p>Vi designer og bygger hjemmesider, der løfter førstehåndsindtrykket og gør næste skridt lettere for kunden.</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="100">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="4" width="7" height="7" rx="1.5"></rect>
                        <rect x="13" y="4" width="7" height="7" rx="1.5"></rect>
                        <rect x="4" y="13" width="7" height="7" rx="1.5"></rect>
                        <rect x="13" y="13" width="7" height="7" rx="1.5"></rect>
                    </svg>
                </div>
                <h3>Frontend & UX</h3>
                <p>Vi skaber roligere interfaces og bedre contentflow, så siderne er nemmere at bruge og nemmere at stole på.</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="200">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 7.5h8"></path>
                        <path d="M8 12h8"></path>
                        <path d="M8 16.5h5"></path>
                        <rect x="4" y="4" width="16" height="16" rx="2.5"></rect>
                    </svg>
                </div>
                <h3>Branding & visuel retning</h3>
                <p>Vi skærper den visuelle retning, så brand, typografi, farver og sidehierarki hænger bedre sammen.</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="300">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                        <path d="M4 18h3"></path>
                        <path d="M17 6h3"></path>
                    </svg>
                </div>
                <h3>Custom funktioner</h3>
                <p>Vi bygger de flows, integrationer og små systemer, der gør løsningen mere brugbar end en standardtemplate.</p>
            </article>
        </div>
    </div>
</section>

<section class="kh-home-process">
    <div class="kf-container">
        <div class="kh-home-process-copy reveal">
            <span class="oo2-section-label">Proces</span>
            <h2>En enkel proces med højere kvalitet og mindre støj.</h2>
            <p class="kh-home-process-intro-text">Vi holder projektet tæt, så retningen er klar, beslutningerne er enkle og execution bliver bedre hele vejen gennem.</p>
        </div>

        <article class="kh-home-process-stage reveal" data-delay="100">
            <div class="kh-home-process-stage-controls">
                <button type="button" class="kh-home-process-arrow" @onclick="PreviousProcessStep" aria-label="Forrige trin">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <button type="button" class="kh-home-process-arrow" @onclick="NextProcessStep" aria-label="Næste trin">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                    </svg>
                </button>
            </div>

            <div class="kh-home-process-stage-grid">
                <div class="kh-home-process-stage-copy">
                    <div class="kh-home-process-stage-number">@ActiveProcessStep.Number</div>
                    <h3>@ActiveProcessStep.Title</h3>
                    <p class="kh-home-process-stage-description">@ActiveProcessStep.Description</p>

                    <div class="kh-home-process-stage-includes">
                        <ul>
                            @foreach (var item in ActiveProcessStep.Includes)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="kh-home-process-stage-media">
                    <img src="@ActiveProcessStep.ImageUrl" alt="@ActiveProcessStep.ImageAlt" loading="lazy" />
                </div>
            </div>
        </article>
    </div>
</section>

<section class="kh-home-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">Kontakt</span>
        <h2>Hvis jeres website eller digitale udtryk skal være skarpere, tager vi gerne den første samtale.</h2>
        <p>Vi passer bedst til virksomheder, der vil løfte niveauet med et lille team og en mere gennemført proces.</p>
        <a href="/booking" class="oo2-cta-link">BOOK ET MØDE</a>
    </div>
</section>

<SiteFooter />

@code {
    private readonly ProcessStep[] processSteps =
    [
        new(
            "01",
            "Afklaring",
            "Vi starter med mål, scope og prioriteringer, så projektet får en tydelig retning, før vi designer eller bygger noget.",
            [
                "Kickoff og forventningsafstemning",
                "Mål, målgruppe og vigtigste use cases",
                "Prioritering af sider, funktioner og indhold",
                "Første retning for tidsplan og næste skridt"
            ],
            "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80",
            "Workshop og afklaringsmøde ved et bord"
        ),
        new(
            "02",
            "Design & struktur",
            "Her former vi oplevelsen, strukturen og den visuelle retning, så brugeren forstår siden hurtigt, og brandet står mere samlet.",
            [
                "Wireframes og contentflow",
                "Visuel retning, typografi og farver",
                "Design af nøglesektioner og CTA-punkter",
                "Feedbackrunde og designjusteringer"
            ],
            "https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80",
            "Arbejdsbord med laptop og designmateriale"
        ),
        new(
            "03",
            "Build & launch",
            "Til sidst bygger vi den færdige løsning, tester den i praksis og gør den klar til at gå live uden unødvendig friktion.",
            [
                "Frontend-udvikling og responsive detaljer",
                "Opsætning af formularer, integrationer og flows",
                "Kvalitetstjek på mobil, tablet og desktop",
                "Launch, overlevering og næste anbefalinger"
            ],
            "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
            "Skærm med data og udviklingsarbejde"
        )
    ];

    private int activeProcessStepIndex;

    private ProcessStep ActiveProcessStep => processSteps[activeProcessStepIndex];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }

    private void PreviousProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex - 1 + processSteps.Length) % processSteps.Length;
    }

    private void NextProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex + 1) % processSteps.Length;
    }

    private sealed record ProcessStep(
        string Number,
        string Title,
        string Description,
        string[] Includes,
        string ImageUrl,
        string ImageAlt);
}
