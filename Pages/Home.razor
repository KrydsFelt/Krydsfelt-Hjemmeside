@page "/"
@inherits LocalizedComponentBase
@inject IJSRuntime JS

<PageTitle>KrydsFelt</PageTitle>

<SiteHeader CurrentPage="home" ContactHref="/booking" />

<section class="kh-home-hero">
    <div class="kf-container">
        <div class="kh-home-hero-grid kh-home-hero-grid-minimal">
            <div class="kh-home-hero-copy">
                <h1 class="kh-home-title" data-animate="words" @key="Lang.CurrentLanguage">@Lang.T("home.hero.title")</h1>
                <p class="kh-home-text reveal">@Lang.T("home.hero.text")</p>
                <div class="kh-home-actions">
                    <a href="/booking" class="kf-btn kf-btn-primary"><span>@Lang.T("home.hero.bookMeeting")</span></a>
                    <a href="/ydelser" class="kf-btn kf-btn-secondary"><span>@Lang.T("home.hero.seeServices")</span></a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="kh-home-profile">
    <div class="kf-container kh-home-profile-grid">
        <div class="kh-home-profile-copy reveal">
            <span class="oo2-section-label">@Lang.T("home.profile.label")</span>
            <h2>@Lang.T("home.profile.heading")</h2>

            <div class="kh-home-profile-media kh-home-profile-media-mobile reveal">
                <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
                <div class="kh-home-profile-stats">
                    <div><strong>4+</strong><span>@Lang.T("home.profile.stat.years")</span></div>
                    <div><strong>43</strong><span>@Lang.T("home.profile.stat.partners")</span></div>
                    <div><strong>100%</strong><span>@Lang.T("home.profile.stat.satisfaction")</span></div>
                </div>
            </div>

            <p>@Lang.T("home.profile.p1")</p>
            <p>@Lang.T("home.profile.p2")</p>
            <p>@Lang.T("home.profile.p3")</p>
            <a href="/om-os" class="kh-home-inline-link">@Lang.T("home.profile.readMore")</a>

            <div class="kh-home-socials">
                <a href="#" aria-label="Instagram" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.5" cy="6.5" r="1"></circle>
                    </svg>
                </a>
                <a href="#" aria-label="LinkedIn" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M6.94 8.5H3.56V20h3.38V8.5Zm-1.69-1.56c1.08 0 1.94-.74 1.94-1.72-.02-1-.86-1.72-1.92-1.72-1.06 0-1.94.72-1.94 1.72 0 .98.84 1.72 1.9 1.72h.02ZM20 13.05c0-3.47-1.85-5.08-4.32-5.08-1.99 0-2.88 1.1-3.37 1.87V8.5H8.94c.05.89 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.12-.92.27-.68.88-1.38 1.91-1.38 1.35 0 1.89 1.04 1.89 2.56V20H20v-6.95Z"></path>
                    </svg>
                </a>
                <a href="mailto:krydsfelt.info@gmail.com" aria-label="Email" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 7l9 6 9-6"></path>
                    </svg>
                </a>
            </div>
        </div>

        <div class="kh-home-profile-media reveal" data-delay="140">
            <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
            <div class="kh-home-profile-stats">
                <div>
                    <strong>4+</strong>
                    <span>@Lang.T("home.profile.stat.years")</span>
                </div>
                <div>
                    <strong>43</strong>
                    <span>@Lang.T("home.profile.stat.partners")</span>
                </div>
                <div>
                    <strong>100%</strong>
                    <span>@Lang.T("home.profile.stat.satisfaction")</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="kh-home-services">
    <div class="kf-container">
        <div class="kh-home-services-top reveal">
            <div class="kh-home-section-head">
                <span class="oo2-section-label">@Lang.T("home.services.label")</span>
                <h2>@Lang.T("home.services.heading")</h2>
                <p>@Lang.T("home.services.text")</p>
            </div>

            <a href="/ydelser" class="kh-home-services-link">@Lang.T("home.services.seeAll")</a>
        </div>

        <div class="kh-home-service-grid kh-home-service-grid-featured">
            <article class="kh-home-service-card kh-home-service-card-featured reveal">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 18h16"></path>
                        <path d="M7 18V9"></path>
                        <path d="M12 18V6"></path>
                        <path d="M17 18v-4"></path>
                        <path d="M5 9.5 9 6l3 2.5 6-4"></path>
                    </svg>
                </div>
                <h3>@Lang.T("home.service1.title")</h3>
                <p>@Lang.T("home.service1.desc")</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="100">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="4" width="7" height="7" rx="1.5"></rect>
                        <rect x="13" y="4" width="7" height="7" rx="1.5"></rect>
                        <rect x="4" y="13" width="7" height="7" rx="1.5"></rect>
                        <rect x="13" y="13" width="7" height="7" rx="1.5"></rect>
                    </svg>
                </div>
                <h3>@Lang.T("home.service2.title")</h3>
                <p>@Lang.T("home.service2.desc")</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="200">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M8 7.5h8"></path>
                        <path d="M8 12h8"></path>
                        <path d="M8 16.5h5"></path>
                        <rect x="4" y="4" width="16" height="16" rx="2.5"></rect>
                    </svg>
                </div>
                <h3>@Lang.T("home.service3.title")</h3>
                <p>@Lang.T("home.service3.desc")</p>
            </article>
            <article class="kh-home-service-card kh-home-service-card-featured reveal" data-delay="300">
                <div class="kh-home-service-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                        <path d="M4 18h3"></path>
                        <path d="M17 6h3"></path>
                    </svg>
                </div>
                <h3>@Lang.T("home.service4.title")</h3>
                <p>@Lang.T("home.service4.desc")</p>
            </article>
        </div>
    </div>
</section>

<section class="kh-home-process">
    <div class="kf-container">
        <div class="kh-home-process-copy reveal">
            <span class="oo2-section-label">@Lang.T("home.process.label")</span>
            <h2>@Lang.T("home.process.heading")</h2>
            <p class="kh-home-process-intro-text">@Lang.T("home.process.intro")</p>
        </div>

        <article class="kh-home-process-stage reveal" data-delay="100">
            <div class="kh-home-process-stage-controls">
                <button type="button" class="kh-home-process-arrow" @onclick="PreviousProcessStep" aria-label="@Lang.T("nav.prevStep")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </button>
                <button type="button" class="kh-home-process-arrow" @onclick="NextProcessStep" aria-label="@Lang.T("nav.nextStep")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6"></path>
                    </svg>
                </button>
            </div>

            <div class="kh-home-process-stage-grid">
                <div class="kh-home-process-stage-copy">
                    <div class="kh-home-process-stage-number">@ActiveProcessStep.Number</div>
                    <h3>@ActiveProcessStep.Title</h3>
                    <p class="kh-home-process-stage-description">@ActiveProcessStep.Description</p>

                    <div class="kh-home-process-stage-includes">
                        <ul>
                            @foreach (var item in ActiveProcessStep.Includes)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="kh-home-process-stage-media">
                    <img src="@ActiveProcessStep.ImageUrl" alt="@ActiveProcessStep.ImageAlt" loading="lazy" />
                </div>
            </div>
        </article>
    </div>
</section>

<section class="kh-home-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">@Lang.T("home.cta.label")</span>
        <h2>@Lang.T("home.cta.heading")</h2>
        <p>@Lang.T("home.cta.text")</p>
        <a href="/booking" class="oo2-cta-link">@Lang.T("home.cta.link")</a>
    </div>
</section>

<SiteFooter />

@code {
    private int activeProcessStepIndex;
    private bool _reanimationNeeded;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Lang.OnLanguageChanged += OnLangChanged;
    }

    private void OnLangChanged() => _reanimationNeeded = true;

    private ProcessStep ActiveProcessStep => GetProcessSteps()[activeProcessStepIndex];

    private ProcessStep[] GetProcessSteps() =>
    [
        new(
            "01",
            Lang.T("home.step1.title"),
            Lang.T("home.step1.desc"),
            [
                Lang.T("home.step1.i1"),
                Lang.T("home.step1.i2"),
                Lang.T("home.step1.i3"),
                Lang.T("home.step1.i4")
            ],
            "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step1.alt")
        ),
        new(
            "02",
            Lang.T("home.step2.title"),
            Lang.T("home.step2.desc"),
            [
                Lang.T("home.step2.i1"),
                Lang.T("home.step2.i2"),
                Lang.T("home.step2.i3"),
                Lang.T("home.step2.i4")
            ],
            "https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step2.alt")
        ),
        new(
            "03",
            Lang.T("home.step3.title"),
            Lang.T("home.step3.desc"),
            [
                Lang.T("home.step3.i1"),
                Lang.T("home.step3.i2"),
                Lang.T("home.step3.i3"),
                Lang.T("home.step3.i4")
            ],
            "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=1200&q=80",
            Lang.T("home.step3.alt")
        )
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _reanimationNeeded)
        {
            _reanimationNeeded = false;
            await JS.InvokeVoidAsync("initAnimations");
        }
    }

    public new void Dispose()
    {
        Lang.OnLanguageChanged -= OnLangChanged;
        base.Dispose();
    }

    private void PreviousProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex - 1 + 3) % 3;
    }

    private void NextProcessStep()
    {
        activeProcessStepIndex = (activeProcessStepIndex + 1) % 3;
    }

    private sealed record ProcessStep(
        string Number,
        string Title,
        string Description,
        string[] Includes,
        string ImageUrl,
        string ImageAlt);
}
