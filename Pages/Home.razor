<section class="kh-home-profile">
    <div class="kf-container kh-home-profile-grid">
        <div class="kh-home-profile-copy reveal">
            <span class="oo2-section-label">@Lang.T("home.profile.label")</span>
            <h2>@Lang.T("home.profile.heading")</h2>

            <div class="kh-home-profile-media kh-home-profile-media-mobile reveal">
                <img src="Pictures/Tony.jpeg" alt="Tony Xtruong" />
                <div class="kh-home-profile-stats">
                    <div><strong>4+</strong><span>@Lang.T("home.profile.stat.years")</span></div>
                    <div><strong>43</strong><span>@Lang.T("home.profile.stat.partners")</span></div>
                    <div><strong>100%</strong><span>@Lang.T("home.profile.stat.satisfaction")</span></div>
                </div>
            </div>

            <p>@Lang.T("home.profile.p1")</p>
            <p>@Lang.T("home.profile.p2")</p>
            <p>@Lang.T("home.profile.p3")</p>
            <a href="/om-os" class="kh-home-inline-link">@Lang.T("home.profile.readMore")</a>

            <div class="kh-home-socials">
                <a href="#" aria-label="Instagram" class="kh-home-social-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.5" cy="6.5" r="1"></circle>
