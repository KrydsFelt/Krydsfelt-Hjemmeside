@page "/ydelser"
@inherits LocalizedComponentBase
@inject IJSRuntime JS

<PageTitle>Ydelser – KrydsFelt</PageTitle>

<!-- NAV + HERO WRAPPER -->
<div class="yd2-hero-wrapper">
    <SiteHeader CurrentPage="services" ContactHref="/booking" />

    <!-- HERO - DARK WITH BLUE GLOW -->
    <section class="yd2-hero">
        <div class="yd2-hero-glow"></div>
        <div class="kf-container yd2-hero-inner">
            <div class="yd2-hero-content">
                <span class="yd2-hero-badge">@Lang.T("yd2.hero.badge")</span>
                <h1 class="yd2-hero-title">@Lang.T("yd2.hero.title")</h1>
                <p class="yd2-hero-desc">@Lang.T("yd2.hero.desc")</p>

                <!-- Service Badge Tags -->
                <div class="yd2-service-tags">
                    <span class="yd2-service-tag">Webudvikling</span>
                    <span class="yd2-service-tag">Meta Ads</span>
                    <span class="yd2-service-tag">Branding & Design</span>
                    <span class="yd2-service-tag">Custom Projekt</span>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- CLIENT LOGOS STRIP -->
<section class="yd2-logos">
    <div class="kf-container">
        <p class="yd2-logos-label">@Lang.T("yd2.logos.label")</p>
        <div class="yd2-logos-grid">
            <div class="yd2-logo-item">
                <span>Herthadalen</span>
            </div>
            <div class="yd2-logo-item">
                <span>Falcon</span>
            </div>
            <div class="yd2-logo-item">
                <span>Pit Stop</span>
            </div>
            <div class="yd2-logo-item">
                <span>Polax</span>
            </div>
        </div>
    </div>
</section>

<!-- SERVICES GRID -->
<section class="yd2-services">
    <div class="kf-container">
        <div class="yd2-services-head reveal">
            <span class="oo2-section-label">@Lang.T("yd2.services.label")</span>
            <h2>@Lang.T("yd2.services.heading")</h2>
        </div>

        <div class="yd2-services-grid">
            <!-- Webudvikling Card -->
            <a href="/ydelser/webudvikling" class="yd2-service-card reveal">
                <div class="yd2-service-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                        <line x1="2" y1="17" x2="22" y2="17"></line>
                        <line x1="6" y1="21" x2="18" y2="21"></line>
                    </svg>
                </div>
                <h3>@Lang.T("yd2.card.webudvikling.title")</h3>
                <p>@Lang.T("yd2.card.webudvikling.desc")</p>
                <span class="yd2-service-card-link">Læs mere →</span>
            </a>

            <!-- Meta Ads Card -->
            <a href="/ydelser/meta-ads" class="yd2-service-card reveal" data-delay="100">
                <div class="yd2-service-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M6 9l6-3 6 3v6l-6 3-6-3V9z"></path>
                        <path d="M9 14v3"></path>
                        <path d="M15 14v3"></path>
                    </svg>
                </div>
                <h3>@Lang.T("yd2.card.metaads.title")</h3>
                <p>@Lang.T("yd2.card.metaads.desc")</p>
                <span class="yd2-service-card-link">Læs mere →</span>
            </a>

            <!-- Branding & Design Card -->
            <a href="/ydelser/branding-design" class="yd2-service-card reveal" data-delay="200">
                <div class="yd2-service-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"></path>
                        <path d="M12 7v10"></path>
                        <path d="M7 12h10"></path>
                    </svg>
                </div>
                <h3>@Lang.T("yd2.card.branding.title")</h3>
                <p>@Lang.T("yd2.card.branding.desc")</p>
                <span class="yd2-service-card-link">Læs mere →</span>
            </a>

            <!-- Custom Project Card -->
            <a href="/ydelser/custom-project" class="yd2-service-card reveal" data-delay="300">
                <div class="yd2-service-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"></path>
                        <polyline points="10 17 14 13 10 9"></polyline>
                    </svg>
                </div>
                <h3>@Lang.T("yd2.card.custom.title")</h3>
                <p>@Lang.T("yd2.card.custom.desc")</p>
                <span class="yd2-service-card-link">Læs mere →</span>
            </a>
        </div>
    </div>
</section>

<!-- BOTTOM CTA -->
<section class="kh-about-cta">
    <div class="kf-container kh-home-cta-inner">
        <span class="oo2-section-label">@Lang.T("yd2.cta.label")</span>
        <h2>@Lang.T("yd2.cta.heading")</h2>
        <p>@Lang.T("yd2.cta.desc")</p>
        <a href="/booking" class="oo2-cta-link">@Lang.T("yd2.cta.link")</a>
    </div>
</section>

<SiteFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
