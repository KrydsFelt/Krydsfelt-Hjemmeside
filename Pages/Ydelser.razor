@page "/ydelser"
@inject IJSRuntime JS

<PageTitle>Ydelser – KrydsFelt</PageTitle>

<!-- NAV + HERO WRAPPER -->
<div class="yd-hero-wrapper">

    <nav class="kf-nav">
        <div class="kf-nav-inner">
            <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
            <div class="kf-nav-links">
                <a href="/ydelser" class="kf-nav-active">Ydelser</a>
                <a href="/om-os">Om os</a>
            </div>
            <button class="kf-nav-hamburger @(navOpen ? "open" : "")" @onclick="() => navOpen = !navOpen" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <a href="/#contact" class="kf-nav-contact-btn">Kontakt</a>
        </div>
        <div class="kf-nav-mobile @(navOpen ? "open" : "")">
            <a href="/ydelser" @onclick="() => navOpen = false">Ydelser</a>
            <a href="/om-os" @onclick="() => navOpen = false">Om os</a>
            <a href="/#contact" @onclick="() => navOpen = false">Kontakt</a>
        </div>
    </nav>

    <!-- HERO - DARK WITH GLOW -->
    <section class="yd-hero-v2">
        <div class="kf-container">
            <div class="yd-hero-card-v2">
                <span class="yd-hero-badge">YDELSER</span>
                <h1 class="yd-hero-title">Hvor digital vækst struktureres</h1>
                <p class="yd-hero-desc">Vores ydelser danner et stærkt digitalt fundament. Fra strategi og design til udvikling og systemer, der giver klar indsigt i performance.</p>
                <a href="/#contact" class="yd-hero-btn">DISKUTER DIT PROJEKT →</a>
            </div>
        </div>
    </section>
</div>

<!-- EXPERTISE SECTION - TEXT BASED LIST -->
<section class="expertise-section">
    <div class="kf-container">
        <div class="expertise-layout">
            <!-- LEFT: Heading & Description -->
            <div class="expertise-left">
                <span class="expertise-label reveal">EKSPERTISE</span>
                <h2 class="expertise-heading reveal">Designet til skalerbar ydelse</h2>
                <p class="expertise-description reveal" data-delay="100">Vores team af strateger og specialister strukturerer, bygger og optimerer digital vækst med disciplin og klart fokus på resultater.</p>
            </div>

            <!-- RIGHT: Service List -->
            <div class="expertise-right">
                <!-- 01: Brand Strategy & Identity -->
                <div class="expertise-item reveal">
                    <div class="expertise-item-header">
                        <span class="expertise-item-num">01</span>
                        <h3 class="expertise-item-title">Brand Strategi & Identitet</h3>
                    </div>
                    <p class="expertise-item-desc">Vi bygger det strategiske fundament, der guider, hvordan dit mærke positionerer sig, kommunikerer og vokser på digitalt marked.</p>
                </div>

                <!-- 02: Webudvikling -->
                <div class="expertise-item reveal" data-delay="100">
                    <div class="expertise-item-header">
                        <span class="expertise-item-num">02</span>
                        <h3 class="expertise-item-title">Webudvikling</h3>
                        <span class="expertise-item-arrow">→</span>
                    </div>
                    <p class="expertise-item-desc">Vi udvikler skalerbare hjemmesider, der styrker din digitale tilstedeværelse, tiltrækker det rette publikum og konverterer besøgende til muligheder.</p>
                </div>

                <!-- 03: Skræddersyede Systemer -->
                <div class="expertise-item reveal" data-delay="200">
                    <div class="expertise-item-header">
                        <span class="expertise-item-num">03</span>
                        <h3 class="expertise-item-title">Lead Generation</h3>
                        <span class="expertise-item-arrow">→</span>
                    </div>
                    <p class="expertise-item-desc">Vi bygger lead generation-systemer, der konverterer trafik til reelle muligheder. Funnels, landingpages og kampagner er designet til at øge konvertering.</p>
                </div>

                <!-- 04: Design & UX -->
                <div class="expertise-item reveal" data-delay="300">
                    <div class="expertise-item-header">
                        <span class="expertise-item-num">04</span>
                        <h3 class="expertise-item-title">Design & UX</h3>
                        <span class="expertise-item-arrow">→</span>
                    </div>
                    <p class="expertise-item-desc">Intuitive og tilgængelige designløsninger, der skaber fremragende brugeroplevelser på alle enheder og kontaktpunkter.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- APPROACH SECTION - VERTICAL TIMELINE -->
<section class="approach-section">
    <div class="approach-bg-map"></div>
    <div class="kf-container">
        <div class="approach-layout">
            <!-- LEFT: Heading & CTA -->
            <div class="approach-left">
                <span class="approach-label">VOR TILGANG</span>
                <h2 class="approach-heading">Sådan arbejder vi sammen</h2>
                <p class="approach-description">Vores tilgang er klar og struktureret. Gennem definerede trin bygger vi digitale løsninger, der giver mening, skaber klarhed og fortsætter med at performe fra første indsigt til løbende udvikling.</p>
                <a href="/#contact" class="approach-btn">DISKUTER DIT PROJEKT →</a>
            </div>

            <!-- RIGHT: Timeline -->
            <div class="approach-right">
                <div class="approach-timeline">
                    <!-- Step 1 -->
                    <div class="approach-step reveal">
                        <div class="approach-step-circle">1</div>
                        <div class="approach-step-content">
                            <h3 class="approach-step-title">INDSIGT</h3>
                            <p class="approach-step-desc">Vi tager os tid til at forstå din organisation, mål og udfordringer. Det giver os den kontekst, vi har brug for, før vi træffer strategiske beslutninger.</p>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="approach-step reveal" data-delay="100">
                        <div class="approach-step-circle">2</div>
                        <div class="approach-step-content">
                            <h3 class="approach-step-title">STRATEGI</h3>
                            <p class="approach-step-desc">Vi definerer retningen og prioriteterne i en klar plan, der danner fundament for alt det, der følger.</p>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="approach-step reveal" data-delay="200">
                        <div class="approach-step-circle">3</div>
                        <div class="approach-step-content">
                            <h3 class="approach-step-title">OPBYGNING</h3>
                            <p class="approach-step-desc">Vi designer og udvikler en løsning, der er logisk struktureret, teknisk robust og klar til at understøtte vækst.</p>
                        </div>
                    </div>

                    <!-- Step 4 -->
                    <div class="approach-step reveal" data-delay="300">
                        <div class="approach-step-circle">4</div>
                        <div class="approach-step-content">
                            <h3 class="approach-step-title">LANCERING</h3>
                            <p class="approach-step-desc">Vi tester grundigt, guider lanceringen og sikrer, at alt går live smooth og pålideligt.</p>
                        </div>
                    </div>

                    <!-- Step 5 -->
                    <div class="approach-step reveal" data-delay="400">
                        <div class="approach-step-circle">5</div>
                        <div class="approach-step-content">
                            <h3 class="approach-step-title">SUPPORT</h3>
                            <p class="approach-step-desc">Efter lancering forbliver vi involveret med vedligeholdelse, optimering og løbende udvikling.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="kf-footer">
    <div class="kf-container">
        <div class="kf-footer-content">
            <div class="kf-footer-cta">
                <p class="kf-footer-cta-label">Klar til at blive noget stort?</p>
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-footer-email">krydsfelt.info@gmail.com</a>
                <p style="font-size: 0.85rem; color: #999; margin-top: 0.75rem; font-weight: 500;">Tony Xtruong, Founder & CTO</p>
            </div>
            <div class="kf-footer-links">
                <div class="kf-footer-col">
                    <h5>Udforsk</h5>
                    <a href="/">Hjem</a>
                    <a href="/ydelser">Ydelser</a>
                    <a href="/om-os">Om os</a>
                    <a href="/#contact">Kontakt</a>
                </div>
                <div class="kf-footer-col">
                    <h5>Sociale</h5>
                    <a href="#" target="_blank">LinkedIn</a>
                    <a href="#" target="_blank">Instagram</a>
                    <a href="#" target="_blank">GitHub</a>
                </div>
            </div>
        </div>
        <div class="kf-footer-bottom">
            <p>&copy; 2026 KrydsFelt. Alle rettigheder forbeholdes.</p>
        </div>
    </div>
</footer>

@code {
    bool navOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
