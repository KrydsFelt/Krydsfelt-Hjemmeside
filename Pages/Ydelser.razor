@page "/ydelser"
@inject IJSRuntime JS

<PageTitle>Ydelser – KrydsFelt</PageTitle>

<!-- NAV -->
<nav class="kf-nav">
    <div class="kf-nav-inner">
        <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
        <div class="kf-nav-links">
            <a href="/ydelser" class="kf-nav-active">Ydelser</a>
            <a href="/om-os">Om os</a>
        </div>
    </div>
    <a href="/#contact" class="kf-nav-contact-btn">Kontakt</a>
</nav>

<!-- HERO -->
<section class="yd-hero">
    <div class="yd-hero-glow"></div>
    <div class="yd-hero-scan"></div>
    <div class="kf-container yd-hero-inner">
        <h1>Vores <span class="kf-orange">Ydelser</span></h1>
        <p>Vi tilbyder skræddersyede digitale løsninger, der er bygget til at vokse med din virksomhed. Læs mere om, hvad vi kan gøre for dig.</p>
    </div>
</section>

<!-- SERVICE 1: WEBUDVIKLING -->
<section class="yd-service" id="webudvikling">
    <div class="kf-container yd-service-inner">
        <div class="yd-service-content reveal-left">
            <span class="yd-service-label"><span class="yd-service-label-dot"></span>01</span>
            <h2>Webudvikling</h2>
            <p>Vi bygger moderne, hurtige og brugervenlige hjemmesider og webapplikationer fra bunden. Uanset om du har brug for en simpel præsentationsside eller en kompleks webplatform, leverer vi løsninger, der både ser godt ud og performer.</p>
            <ul class="yd-feature-list">
                <li class="yd-feature-item"><span class="yd-check">✓</span> Skræddersyede hjemmesider</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Single Page Applications</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> E-commerce løsninger</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> SEO-optimering</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Hurtig indlæsningstid</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> CMS-integration</li>
            </ul>
            <div class="yd-tags">
                <span class="yd-tag">Blazor</span>
                <span class="yd-tag">React</span>
                <span class="yd-tag">.NET</span>
                <span class="yd-tag">TypeScript</span>
                <span class="yd-tag">CSS / Tailwind</span>
            </div>
        </div>
        <div class="yd-service-visual reveal-right">
            <div class="yd-icon-wrap">
                <span class="yd-icon-num">01</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<!-- SERVICE 2: SKRÆDDERSYEDE SYSTEMER -->
<section class="yd-service" id="systemer">
    <div class="kf-container yd-service-inner">
        <div class="yd-service-content reveal-right">
            <span class="yd-service-label"><span class="yd-service-label-dot"></span>02</span>
            <h2>Skræddersyede Systemer</h2>
            <p>Standardsoftware passer ikke altid til din forretning. Vi designer og bygger tilpassede systemer, der løser præcis dine udfordringer — fra interne arbejdsgangsværktøjer til komplekse forretningsplatforme med fuld integration til dine eksisterende systemer.</p>
            <ul class="yd-feature-list">
                <li class="yd-feature-item"><span class="yd-check">✓</span> Forretningssystemer</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Workflow-automatisering</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Tredjepartsintegrationer</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Brugervenlig administration</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Skalerbare løsninger</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Rapportering og data</li>
            </ul>
            <div class="yd-tags">
                <span class="yd-tag">.NET</span>
                <span class="yd-tag">C#</span>
                <span class="yd-tag">SQL</span>
                <span class="yd-tag">Azure</span>
                <span class="yd-tag">REST API</span>
            </div>
        </div>
        <div class="yd-service-visual reveal-left">
            <div class="yd-icon-wrap">
                <span class="yd-icon-num">02</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<!-- SERVICE 3: BACKEND -->
<section class="yd-service" id="backend">
    <div class="kf-container yd-service-inner">
        <div class="yd-service-content reveal-left">
            <span class="yd-service-label"><span class="yd-service-label-dot"></span>03</span>
            <h2>Backend-løsninger</h2>
            <p>En stærk backend er fundamentet for enhver digital løsning. Vi bygger robuste og sikre server-side systemer og API'er, der kan håndtere høj trafik, kompleks forretningslogik og problemfri integration med tredjepartssystemer.</p>
            <ul class="yd-feature-list">
                <li class="yd-feature-item"><span class="yd-check">✓</span> REST API & GraphQL</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Databasedesign</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Cloud-hosting (Azure/AWS)</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Sikkerhed & autentificering</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Microservices</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Realtidsdata</li>
            </ul>
            <div class="yd-tags">
                <span class="yd-tag">ASP.NET Core</span>
                <span class="yd-tag">PostgreSQL</span>
                <span class="yd-tag">Redis</span>
                <span class="yd-tag">Docker</span>
                <span class="yd-tag">Azure</span>
            </div>
        </div>
        <div class="yd-service-visual reveal-right">
            <div class="yd-icon-wrap">
                <span class="yd-icon-num">03</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="9" ry="3"/>
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<!-- SERVICE 4: RESPONSIVT DESIGN -->
<section class="yd-service" id="design">
    <div class="kf-container yd-service-inner">
        <div class="yd-service-content reveal-right">
            <span class="yd-service-label"><span class="yd-service-label-dot"></span>04</span>
            <h2>Responsivt Design</h2>
            <p>Dine brugere besøger dig fra alle mulige enheder. Vi sikrer, at din løsning ser ud og fungerer perfekt — fra store desktopskærme til den mindste mobiltelefon. Vi arbejder med et mobile-first mindset og fokuserer på tilgængelighed og brugeroplevelse.</p>
            <ul class="yd-feature-list">
                <li class="yd-feature-item"><span class="yd-check">✓</span> Mobile-first tilgang</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Alle skærmstørrelser</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Tilgængelighed (WCAG)</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Animationer & micro-UX</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Brand-konsistens</li>
                <li class="yd-feature-item"><span class="yd-check">✓</span> Brugertest & iteration</li>
            </ul>
            <div class="yd-tags">
                <span class="yd-tag">Figma</span>
                <span class="yd-tag">CSS</span>
                <span class="yd-tag">WCAG</span>
                <span class="yd-tag">Mobile-first</span>
                <span class="yd-tag">UX/UI</span>
            </div>
        </div>
        <div class="yd-service-visual reveal-left">
            <div class="yd-icon-wrap">
                <span class="yd-icon-num">04</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                    <line x1="12" y1="18" x2="12.01" y2="18"/>
                </svg>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="yd-cta">
    <div class="kf-container yd-cta-inner">
        <h2 class="reveal">Klar til at komme i gang?</h2>
        <p class="reveal" data-delay="100">Fortæl os om dit projekt, og vi finder den bedste løsning til dig.</p>
        <a href="/#contact" class="kf-btn reveal" data-delay="200">Kontakt os &rarr;</a>
    </div>
</section>

<!-- FOOTER -->
<footer class="kf-footer">
    <div class="kf-container">
        <div class="kf-footer-content">
            <div class="kf-footer-cta">
                <p class="kf-footer-cta-label">Klar til at blive noget stort?</p>
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-footer-email">krydsfelt.info@gmail.com</a>
            </div>
            <div class="kf-footer-links">
                <div class="kf-footer-col">
                    <h5>Udforsk</h5>
                    <a href="/">Hjem</a>
                    <a href="/ydelser">Ydelser</a>
                    <a href="/om-os">Om os</a>
                    <a href="/#contact">Kontakt</a>
                </div>
                <div class="kf-footer-col">
                    <h5>Sociale</h5>
                    <a href="#" target="_blank">LinkedIn</a>
                    <a href="#" target="_blank">Instagram</a>
                    <a href="#" target="_blank">GitHub</a>
                </div>
            </div>
        </div>
        <div class="kf-footer-bottom">
            <p>&copy; 2026 KrydsFelt. Alle rettigheder forbeholdes.</p>
        </div>
    </div>
</footer>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }
}
