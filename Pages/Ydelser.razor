@page "/ydelser"
@inject IJSRuntime JS

<PageTitle>Ydelser – KrydsFelt</PageTitle>

<!-- NAV + HERO WRAPPER -->
<div class="yd-hero-wrapper">
    <div id="yd-bg-paths"></div>
    <div class="yd-hero-glow"></div>

    <nav class="kf-nav">
        <div class="kf-nav-inner">
            <a href="/" class="kf-logo-link"><span class="kf-logo">KRYDSFELT</span></a>
            <div class="kf-nav-links">
                <a href="/ydelser" class="kf-nav-active">Ydelser</a>
                <a href="/om-os">Om os</a>
            </div>
        </div>
        <a href="/#contact" class="kf-nav-contact-btn">Kontakt</a>
    </nav>

    <!-- HERO -->
    <section class="yd-hero">
        <div class="kf-container">
            <div class="yd-hero-card">
                <span class="yd-hero-badge">Hvad vi tilbyder</span>
                <h1>Vores <span class="kf-orange">Ydelser</span></h1>
                <p>Vi tilbyder skræddersyede digitale løsninger, der er bygget til at vokse med din virksomhed. Læs mere om, hvad vi kan gøre for dig.</p>
                <div class="yd-hero-stats">
                    <div class="yd-hero-stat"><span class="yd-hero-stat-num">4+</span><span class="yd-hero-stat-label">Kernekompetencer</span></div>
                    <div class="yd-hero-stat-divider"></div>
                    <div class="yd-hero-stat"><span class="yd-hero-stat-num">100%</span><span class="yd-hero-stat-label">Skræddersyede løsninger</span></div>
                    <div class="yd-hero-stat-divider"></div>
                    <div class="yd-hero-stat"><span class="yd-hero-stat-num">∞</span><span class="yd-hero-stat-label">Skalerbarhed</span></div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- SERVICES LIST -->
<section class="yd-services-section">
    <div class="kf-container">

        <div class="yd-service-row reveal" id="webudvikling">
            <span class="yd-row-num">01</span>
            <div class="yd-row-head">
                <div class="yd-row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                </div>
                <div>
                    <h3>Webudvikling</h3>
                    <p>Moderne, hurtige hjemmesider og webapplikationer fra bunden — fra simpel præsentationsside til kompleks webplatform.</p>
                </div>
            </div>
            <div class="yd-row-features">
                <span>Skræddersyede hjemmesider</span>
                <span>Single Page Applications</span>
                <span>E-commerce løsninger</span>
                <span>SEO-optimering</span>
                <span>Hurtig indlæsningstid</span>
                <span>CMS-integration</span>
            </div>
            <div class="yd-row-tags">
                <span class="yd-tag">Blazor</span>
                <span class="yd-tag">React</span>
                <span class="yd-tag">.NET</span>
                <span class="yd-tag">TypeScript</span>
            </div>
        </div>

        <div class="yd-service-row reveal" data-delay="80" id="systemer">
            <span class="yd-row-num">02</span>
            <div class="yd-row-head">
                <div class="yd-row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                    </svg>
                </div>
                <div>
                    <h3>Skræddersyede Systemer</h3>
                    <p>Tilpassede systemer der løser præcis dine udfordringer — fra workflow-værktøjer til komplekse forretningsplatforme.</p>
                </div>
            </div>
            <div class="yd-row-features">
                <span>Forretningssystemer</span>
                <span>Workflow-automatisering</span>
                <span>Tredjepartsintegrationer</span>
                <span>Skalerbare løsninger</span>
                <span>Rapportering og data</span>
                <span>Brugervenlig admin</span>
            </div>
            <div class="yd-row-tags">
                <span class="yd-tag">.NET</span>
                <span class="yd-tag">C#</span>
                <span class="yd-tag">Azure</span>
                <span class="yd-tag">REST API</span>
            </div>
        </div>

        <div class="yd-service-row reveal" data-delay="160" id="backend">
            <span class="yd-row-num">03</span>
            <div class="yd-row-head">
                <div class="yd-row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <ellipse cx="12" cy="5" rx="9" ry="3"/>
                        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                    </svg>
                </div>
                <div>
                    <h3>Backend-løsninger</h3>
                    <p>Robuste API'er og server-side systemer der håndterer høj trafik, kompleks logik og sikker integration.</p>
                </div>
            </div>
            <div class="yd-row-features">
                <span>REST API & GraphQL</span>
                <span>Databasedesign</span>
                <span>Cloud-hosting</span>
                <span>Sikkerhed & auth</span>
                <span>Microservices</span>
                <span>Realtidsdata</span>
            </div>
            <div class="yd-row-tags">
                <span class="yd-tag">ASP.NET Core</span>
                <span class="yd-tag">PostgreSQL</span>
                <span class="yd-tag">Docker</span>
                <span class="yd-tag">Azure</span>
            </div>
        </div>

        <div class="yd-service-row reveal" data-delay="240" id="design">
            <span class="yd-row-num">04</span>
            <div class="yd-row-head">
                <div class="yd-row-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#E8622A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                        <line x1="12" y1="18" x2="12.01" y2="18"/>
                    </svg>
                </div>
                <div>
                    <h3>Responsivt Design</h3>
                    <p>Perfekt på alle enheder — fra store desktops til mobil. Mobile-first med fokus på tilgængelighed og brugeroplevelse.</p>
                </div>
            </div>
            <div class="yd-row-features">
                <span>Mobile-first tilgang</span>
                <span>Alle skærmstørrelser</span>
                <span>Tilgængelighed (WCAG)</span>
                <span>Animationer & micro-UX</span>
                <span>Brand-konsistens</span>
                <span>Brugertest & iteration</span>
            </div>
            <div class="yd-row-tags">
                <span class="yd-tag">Figma</span>
                <span class="yd-tag">CSS</span>
                <span class="yd-tag">WCAG</span>
                <span class="yd-tag">UX/UI</span>
            </div>
        </div>

    </div>
</section>

<!-- CTA -->
<section class="yd-cta">
    <div class="kf-container yd-cta-inner">
        <h2 class="reveal">Klar til at komme i gang?</h2>
        <p class="reveal" data-delay="100">Fortæl os om dit projekt, og vi finder den bedste løsning til dig.</p>
        <a href="/#contact" class="kf-btn reveal" data-delay="200">Kontakt os &rarr;</a>
    </div>
</section>

<!-- FOOTER -->
<footer class="kf-footer">
    <div class="kf-container">
        <div class="kf-footer-content">
            <div class="kf-footer-cta">
                <p class="kf-footer-cta-label">Klar til at blive noget stort?</p>
                <a href="mailto:krydsfelt.info@gmail.com" class="kf-footer-email">krydsfelt.info@gmail.com</a>
            </div>
            <div class="kf-footer-links">
                <div class="kf-footer-col">
                    <h5>Udforsk</h5>
                    <a href="/">Hjem</a>
                    <a href="/ydelser">Ydelser</a>
                    <a href="/om-os">Om os</a>
                    <a href="/#contact">Kontakt</a>
                </div>
                <div class="kf-footer-col">
                    <h5>Sociale</h5>
                    <a href="#" target="_blank">LinkedIn</a>
                    <a href="#" target="_blank">Instagram</a>
                    <a href="#" target="_blank">GitHub</a>
                </div>
            </div>
        </div>
        <div class="kf-footer-bottom">
            <p>&copy; 2026 KrydsFelt. Alle rettigheder forbeholdes.</p>
        </div>
    </div>
</footer>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
            await JS.InvokeVoidAsync("initBackgroundPaths", "yd-bg-paths");
        }
    }
}
