@page "/booking"
@using System.ComponentModel.DataAnnotations
@inherits LocalizedComponentBase
@inject IJSRuntime JS

<PageTitle>Booking – KrydsFelt</PageTitle>

<SiteHeader CurrentPage="booking" ContactHref="/booking" />

<section class="bk-shell">
    <div class="kf-container">
        <div class="bk-layout">
            <div class="bk-copy reveal">
                <span class="bk-label">@Lang.T("bk.label")</span>
                <h1>@Lang.T("bk.heading")</h1>
                <p>@Lang.T("bk.p1")</p>
                <p>@Lang.T("bk.p2")</p>

                <div class="bk-quick-points">
                    <div>
                        <span>@Lang.T("bk.format.label")</span>
                        <strong>@Lang.T("bk.format.value")</strong>
                    </div>
                    <div>
                        <span>@Lang.T("bk.focus.label")</span>
                        <strong>@Lang.T("bk.focus.value")</strong>
                    </div>
                </div>
            </div>

            <div class="bk-card reveal" data-delay="120">
                <div class="bk-card-intro">
                    <span>@Lang.T("bk.card.intro")</span>
                    <p>@Lang.T("bk.card.sub")</p>
                </div>

                <EditForm Model="@request" OnValidSubmit="@SubmitForm">
                    <DataAnnotationsValidator />
                    <div class="bk-grid">
                        <div class="bk-field">
                            <label for="customerName">@Lang.T("bk.field.name")</label>
                            <InputText id="customerName" @bind-Value="request.CustomerName" />
                            <ValidationMessage For="@(() => request.CustomerName)" />
                        </div>

                        <div class="bk-field">
                            <label for="companyName">@Lang.T("bk.field.company")</label>
                            <InputText id="companyName" @bind-Value="request.CompanyName" />
                            <ValidationMessage For="@(() => request.CompanyName)" />
                        </div>

                        <div class="bk-field">
                            <label for="cvr">@Lang.T("bk.field.cvr")</label>
                            <InputText id="cvr" @bind-Value="request.Cvr" />
                        </div>

                        <div class="bk-field">
                            <label for="email">@Lang.T("bk.field.email")</label>
                            <InputText id="email" @bind-Value="request.Email" type="email" />
                            <ValidationMessage For="@(() => request.Email)" />
                        </div>

                        <div class="bk-field bk-field-full">
                            <label for="helpNeeded">@Lang.T("bk.field.help")</label>
                            <InputTextArea id="helpNeeded" @bind-Value="request.HelpNeeded" />
                            <ValidationMessage For="@(() => request.HelpNeeded)" />
                        </div>
                    </div>

                    <button type="submit" class="bk-submit">@Lang.T("bk.submit")</button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <p class="bk-status">@statusMessage</p>
                }
            </div>
        </div>

        <div class="bk-proof reveal">
            <div class="bk-proof-copy">
                <span class="bk-label bk-label-muted">@Lang.T("bk.proof.label")</span>
                <h2>@Lang.T("bk.proof.heading")</h2>
                <p>@Lang.T("bk.proof.text")</p>
            </div>
        </div>

        <section class="bk-locations reveal" data-delay="120">
            <div class="bk-location-head">
                <span class="bk-label bk-label-muted">@Lang.T("bk.locations.label")</span>
                <h2>@Lang.T("bk.locations.heading")</h2>
            </div>

            <article class="bk-location-card">
                <div class="bk-location-media" aria-hidden="true">
                    <div class="bk-location-image">
                        <img src="https://commons.wikimedia.org/wiki/Special:FilePath/Aarhus%20waterfront.jpg" alt="Aarhus waterfront" loading="lazy" />
                        <span class="bk-location-image-label">Aarhus</span>
                    </div>
                    <div class="bk-location-image">
                        <img src="https://commons.wikimedia.org/wiki/Special:FilePath/City%20of%20Aalborg%20skyline%20sunset.jpg" alt="Aalborg skyline" loading="lazy" />
                        <span class="bk-location-image-label">Aalborg</span>
                    </div>
                </div>

                <div class="bk-location-content">
                    <div class="bk-location-meta">
                        <div class="bk-location-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z"></path>
                                <circle cx="12" cy="11" r="2.5"></circle>
                            </svg>
                            <span>Danmark</span>
                        </div>

                        <div class="bk-location-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                                <path d="M3 7l9 6 9-6"></path>
                            </svg>
                            <a href="mailto:krydsfelt.info@gmail.com">krydsfelt.info@gmail.com</a>
                        </div>

                        <div class="bk-location-meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07A19.5 19.5 0 0 1 5.15 12.8 19.8 19.8 0 0 1 2.08 4.1 2 2 0 0 1 4.07 2h3a2 2 0 0 1 2 1.72c.12.9.33 1.77.62 2.61a2 2 0 0 1-.45 2.11L8 9.7a16 16 0 0 0 6.3 6.3l1.26-1.24a2 2 0 0 1 2.11-.45c.84.29 1.71.5 2.61.62A2 2 0 0 1 22 16.92Z"></path>
                            </svg>
                            <a href="tel:+4550366131">+45 50366131</a>
                        </div>
                    </div>
                </div>
            </article>
        </section>
    </div>
</section>

<SiteFooter />

@code {
    private BookingRequest request = new();
    private string? statusMessage;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        Lang.OnLanguageChanged += ResetForm;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }

    private void ResetForm()
    {
        request = new BookingRequest();
        statusMessage = null;
        InvokeAsync(StateHasChanged);
    }

    private async Task SubmitForm()
    {
        var subject = Uri.EscapeDataString($"Bookinganmodning fra {request.CompanyName}");
        var body = Uri.EscapeDataString(
$@"Navn: {request.CustomerName}
Virksomhed: {request.CompanyName}
CVR: {request.Cvr}
Email: {request.Email}

Behov:
{request.HelpNeeded}");

        var mailto = $"mailto:krydsfelt.info@gmail.com?subject={subject}&body={body}";
        statusMessage = Lang.T("bk.mailOpened");
        await JS.InvokeVoidAsync("open", mailto);
    }

    public new void Dispose()
    {
        Lang.OnLanguageChanged -= ResetForm;
        base.Dispose();
    }

    private sealed class BookingRequest
    {
        [Required(ErrorMessage = "Required.")]
        public string CustomerName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Required.")]
        public string CompanyName { get; set; } = string.Empty;

        public string Cvr { get; set; } = string.Empty;

        [Required(ErrorMessage = "Required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Required.")]
        public string HelpNeeded { get; set; } = string.Empty;
    }
}
