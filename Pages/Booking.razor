@page "/booking"
@using System.ComponentModel.DataAnnotations
@inject IJSRuntime JS

<PageTitle>Booking – KrydsFelt</PageTitle>

<SiteHeader CurrentPage="booking" ContactHref="/booking" />

<section class="bk-shell">
    <div class="kf-container">
        <div class="bk-layout">
            <div class="bk-copy reveal">
                <span class="bk-label">Book a call</span>
                <h1>En første samtale, hvis jeres website skal føles skarpere, roligere og mere gennemført.</h1>
                <p>
                    Vi bruger den første samtale på at forstå, hvad der skal løftes, hvor friktionen er i dag, og om vi er det rigtige team til næste version.
                </p>
                <p>
                    Ingen tung pitch. Bare en ærlig vurdering, et par klare vinkler og en retning, hvis der er et godt match.
                </p>

                <div class="bk-quick-points">
                    <div>
                        <span>Format</span>
                        <strong>20-30 min. intro call</strong>
                    </div>
                    <div>
                        <span>Typisk fokus</span>
                        <strong>Website, UX og digital retning</strong>
                    </div>
                </div>
            </div>

            <div class="bk-card reveal" data-delay="120">
                <div class="bk-card-intro">
                    <span>Fortæl os lidt om projektet</span>
                    <p>Vi vender tilbage med næste skridt og et forslag til mødetid.</p>
                </div>

                <EditForm Model="@request" OnValidSubmit="@SubmitForm">
                    <DataAnnotationsValidator />
                    <div class="bk-grid">
                        <div class="bk-field">
                            <label for="customerName">Navn på kunden</label>
                            <InputText id="customerName" @bind-Value="request.CustomerName" />
                            <ValidationMessage For="@(() => request.CustomerName)" />
                        </div>

                        <div class="bk-field">
                            <label for="companyName">Virksomhed</label>
                            <InputText id="companyName" @bind-Value="request.CompanyName" />
                            <ValidationMessage For="@(() => request.CompanyName)" />
                        </div>

                        <div class="bk-field">
                            <label for="cvr">CVR (valgfrit)</label>
                            <InputText id="cvr" @bind-Value="request.Cvr" />
                        </div>

                        <div class="bk-field">
                            <label for="email">Email</label>
                            <InputText id="email" @bind-Value="request.Email" type="email" />
                            <ValidationMessage For="@(() => request.Email)" />
                        </div>

                        <div class="bk-field bk-field-full">
                            <label for="helpNeeded">Hvad har I brug for hjælp til?</label>
                            <InputTextArea id="helpNeeded" @bind-Value="request.HelpNeeded" />
                            <ValidationMessage For="@(() => request.HelpNeeded)" />
                        </div>
                    </div>

                    <button type="submit" class="bk-submit">Send forespørgsel</button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <p class="bk-status">@statusMessage</p>
                }
            </div>
        </div>

        <div class="bk-proof reveal">
            <div class="bk-proof-copy">
                <span class="bk-label bk-label-muted">Why KrydsFelt</span>
                <h2>Et lille team, når I hellere vil have smag, fokus og execution end bureaufriktion.</h2>
                <p>
                    Vi passer bedst til virksomheder, der vil have et roligere og mere premium digitalt udtryk, men stadig have direkte kontakt med dem der faktisk designer og bygger.
                </p>
            </div>
        </div>
    </div>
</section>

<SiteFooter />

@code {
    private BookingRequest request = new();
    private string? statusMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAnimations");
        }
    }

    private async Task SubmitForm()
    {
        var subject = Uri.EscapeDataString($"Bookinganmodning fra {request.CompanyName}");
        var body = Uri.EscapeDataString(
$@"Navn: {request.CustomerName}
Virksomhed: {request.CompanyName}
CVR: {request.Cvr}
Email: {request.Email}

Behov:
{request.HelpNeeded}");

        var mailto = $"mailto:krydsfelt.info@gmail.com?subject={subject}&body={body}";
        statusMessage = "Din mailklient åbnes med bookinganmodningen.";
        await JS.InvokeVoidAsync("open", mailto);
    }

    private sealed class BookingRequest
    {
        [Required(ErrorMessage = "Indtast navn.")]
        public string CustomerName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Indtast virksomhed.")]
        public string CompanyName { get; set; } = string.Empty;

        public string Cvr { get; set; } = string.Empty;

        [Required(ErrorMessage = "Indtast email.")]
        [EmailAddress(ErrorMessage = "Indtast en gyldig email.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Beskriv kort behovet.")]
        public string HelpNeeded { get; set; } = string.Empty;
    }
}
