@page "/showcase"
@inherits LocalizedComponentBase

<PageTitle>Themes Showcase – KrydsFelt</PageTitle>

<SiteHeader CurrentPage="showcase" ContactHref="/booking" />

<section class="showcase-hero">
    <div class="kf-container showcase-inner">
        <span class="showcase-eyebrow">◆ THEMES SHOWCASE</span>
        <h1 class="showcase-title">Pick a Theme</h1>
        <p class="showcase-sub">Different vibes, same agency. Click a card to preview a theme of our website.</p>

        <div class="showcase-grid">
            <a href="/themes/arcade/index.html" class="showcase-card showcase-card-arcade">
                <div class="showcase-card-glow"></div>
                <div class="showcase-card-tag">THEME #01</div>
                <div class="showcase-card-art showcase-card-art-arcade">
                    <svg viewBox="0 0 200 200" aria-hidden="true">
                        <path d="M 20 18 L 50 18 L 100 100 L 50 182 L 20 182 L 70 100 Z" />
                        <path d="M 180 18 L 150 18 L 100 100 L 150 182 L 180 182 L 130 100 Z" />
                    </svg>
                </div>
                <h2 class="showcase-card-title">Arcade</h2>
                <p class="showcase-card-desc">A retro arcade-inspired version. Pixel icons, scanlines, and neon energy.</p>
                <span class="showcase-card-cta">Enter →</span>
            </a>

            <div class="showcase-card showcase-card-locked">
                <div class="showcase-card-tag">THEME #02</div>
                <div class="showcase-card-art showcase-card-art-locked">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h2 class="showcase-card-title">Coming Soon</h2>
                <p class="showcase-card-desc">A new theme is being crafted. Stay tuned.</p>
                <span class="showcase-card-cta">Locked</span>
            </div>

            <div class="showcase-card showcase-card-locked">
                <div class="showcase-card-tag">THEME #03</div>
                <div class="showcase-card-art showcase-card-art-locked">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <h2 class="showcase-card-title">Coming Soon</h2>
                <p class="showcase-card-desc">Another flavor on the way. Watch this space.</p>
                <span class="showcase-card-cta">Locked</span>
            </div>
        </div>
    </div>
</section>

<SiteFooter />
